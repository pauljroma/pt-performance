# Edge Functions Environment Variables Template
# BUILD 138 - Production Configuration
#
# INSTRUCTIONS:
# 1. Copy this file to `.env` (local development only)
# 2. Fill in actual values
# 3. NEVER commit .env to git (already in .gitignore)
# 4. For production, set secrets via: supabase secrets set KEY=value

# ==============================================================================
# OpenAI API Configuration (REQUIRED for AI functions)
# ==============================================================================
# Get your API key from: https://platform.openai.com/api-keys
# Used by: generate-equipment-substitution, ai-nutrition-recommendation, ai-meal-parser
# Cost: ~$0.32/user/month for 1,000 users

OPENAI_API_KEY=sk-proj-REPLACE_WITH_YOUR_OPENAI_API_KEY

# ==============================================================================
# WHOOP API Configuration (OPTIONAL - falls back to mock data)
# ==============================================================================
# Create WHOOP OAuth app at: https://developer.whoop.com
# Used by: sync-whoop-recovery
# Cost: Free (WHOOP API has no usage fees)

# WHOOP OAuth Client ID
WHOOP_CLIENT_ID=your_whoop_client_id_here

# WHOOP OAuth Client Secret
WHOOP_CLIENT_SECRET=your_whoop_client_secret_here

# WHOOP OAuth Redirect URI (must match your OAuth app configuration)
# Example: https://your-app.com/whoop/callback
WHOOP_REDIRECT_URI=https://your-domain.com/whoop/callback

# ==============================================================================
# Supabase Configuration (AUTO-PROVIDED in production)
# ==============================================================================
# These are automatically set by Supabase in Edge Functions
# Only needed for local development with `supabase start`

# Supabase Project URL
# Example: https://abcdefghijklmnop.supabase.co
SUPABASE_URL=http://localhost:54321

# Supabase Service Role Key (full admin access - KEEP SECRET!)
# WARNING: Never expose this key in client-side code
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Supabase Anon Key (public key for client requests)
# Safe to use in client-side code (protected by RLS policies)
SUPABASE_ANON_KEY=your_anon_key_here

# ==============================================================================
# Edge Function Configuration (OPTIONAL)
# ==============================================================================

# Log level for debugging (development only)
# Options: debug, info, warn, error
# Default: info
LOG_LEVEL=info

# Enable verbose logging (development only)
# Set to "true" to enable detailed request/response logging
# Default: false
VERBOSE_LOGGING=false

# ==============================================================================
# OpenAI Model Configuration (OPTIONAL - use defaults)
# ==============================================================================

# Model for equipment substitution (uses GPT-4 Turbo by default)
# Options: gpt-4-turbo-preview, gpt-4, gpt-4-32k
# Default: gpt-4-turbo-preview
OPENAI_SUBSTITUTION_MODEL=gpt-4-turbo-preview

# Model for nutrition recommendations (uses GPT-4o-mini by default)
# Options: gpt-4o-mini, gpt-4-turbo-preview
# Default: gpt-4o-mini (100x cheaper)
OPENAI_NUTRITION_MODEL=gpt-4o-mini

# Model for meal parsing - text only (uses GPT-4o-mini by default)
# Options: gpt-4o-mini, gpt-4-turbo-preview
# Default: gpt-4o-mini
OPENAI_MEAL_PARSER_TEXT_MODEL=gpt-4o-mini

# Model for meal parsing - with image (uses GPT-4 Vision by default)
# Options: gpt-4-vision-preview, gpt-4o
# Default: gpt-4-vision-preview
OPENAI_MEAL_PARSER_IMAGE_MODEL=gpt-4-vision-preview

# Maximum tokens for OpenAI responses
# Default values optimized for cost/quality balance
OPENAI_SUBSTITUTION_MAX_TOKENS=2000
OPENAI_NUTRITION_MAX_TOKENS=800
OPENAI_MEAL_PARSER_MAX_TOKENS=500

# Temperature for OpenAI models (0.0 = deterministic, 1.0 = creative)
# Lower = more consistent, Higher = more varied
OPENAI_SUBSTITUTION_TEMPERATURE=0.3
OPENAI_NUTRITION_TEMPERATURE=0.7
OPENAI_MEAL_PARSER_TEMPERATURE=0.3

# ==============================================================================
# Caching Configuration (OPTIONAL - use defaults)
# ==============================================================================

# WHOOP sync cache duration (seconds)
# Default: 3600 (1 hour)
# Rationale: Recovery doesn't change frequently enough to warrant < 1hr syncs
WHOOP_CACHE_DURATION=3600

# Nutrition recommendation cache duration (seconds)
# Default: 1800 (30 minutes)
# Rationale: Meal timing advice can change as day progresses
NUTRITION_CACHE_DURATION=1800

# ==============================================================================
# Rate Limiting (OPTIONAL - use defaults)
# ==============================================================================

# Max requests per user per hour (to prevent abuse)
# Default: disabled (no rate limiting)
# Recommended: 100 for equipment substitution, 50 for nutrition
MAX_REQUESTS_PER_USER_PER_HOUR=100

# ==============================================================================
# Error Handling (OPTIONAL - use defaults)
# ==============================================================================

# Number of retry attempts for OpenAI API failures
# Default: 3
OPENAI_MAX_RETRIES=3

# Delay between retry attempts (milliseconds)
# Default: 1000 (1 second)
OPENAI_RETRY_DELAY=1000

# Timeout for OpenAI API requests (milliseconds)
# Default: 30000 (30 seconds)
OPENAI_TIMEOUT=30000

# Timeout for database queries (milliseconds)
# Default: 10000 (10 seconds)
DATABASE_TIMEOUT=10000

# ==============================================================================
# WHOOP API Configuration (OPTIONAL - use defaults)
# ==============================================================================

# WHOOP API base URL
# Default: https://api.prod.whoop.com/developer/v1
WHOOP_API_BASE_URL=https://api.prod.whoop.com/developer/v1

# WHOOP OAuth token URL
# Default: https://api.prod.whoop.com/oauth/oauth2/token
WHOOP_OAUTH_TOKEN_URL=https://api.prod.whoop.com/oauth/oauth2/token

# WHOOP API timeout (milliseconds)
# Default: 10000 (10 seconds)
WHOOP_API_TIMEOUT=10000

# ==============================================================================
# Monitoring & Alerting (OPTIONAL)
# ==============================================================================

# Slack webhook for error alerts
# Get from: Slack → Apps → Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Enable Slack alerts for critical errors
# Default: false
ENABLE_SLACK_ALERTS=false

# Sentry DSN for error tracking
# Get from: Sentry → Settings → Projects → [Project] → Client Keys
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Enable Sentry error tracking
# Default: false
ENABLE_SENTRY=false

# ==============================================================================
# Feature Flags (OPTIONAL - use defaults)
# ==============================================================================

# Enable real WHOOP API integration (vs mock data)
# Default: false (mock data for testing)
ENABLE_REAL_WHOOP=false

# Enable AI-powered substitutions (vs rules-based fallback)
# Default: true
ENABLE_AI_SUBSTITUTIONS=true

# Enable nutrition recommendations
# Default: true
ENABLE_NUTRITION_RECOMMENDATIONS=true

# Enable meal photo parsing (GPT-4 Vision)
# Default: true (but costs 100x more than text-only)
ENABLE_MEAL_PHOTO_PARSING=true

# ==============================================================================
# Development / Testing (OPTIONAL)
# ==============================================================================

# Use mock OpenAI responses (for testing without API calls)
# Default: false
MOCK_OPENAI_RESPONSES=false

# Use mock WHOOP responses (for testing without WHOOP API)
# Default: true (always falls back to mock if no OAuth credentials)
MOCK_WHOOP_RESPONSES=true

# Skip RLS policies (DANGEROUS - development only)
# Default: false
# WARNING: Only use in isolated development environment
SKIP_RLS_POLICIES=false

# ==============================================================================
# Production Deployment Notes
# ==============================================================================
#
# To deploy these environment variables to production:
#
# 1. Set secrets via Supabase CLI:
#    supabase secrets set OPENAI_API_KEY=sk-proj-...
#    supabase secrets set WHOOP_CLIENT_ID=...
#    supabase secrets set WHOOP_CLIENT_SECRET=...
#
# 2. Verify secrets are set:
#    supabase secrets list
#
# 3. Secrets are automatically available in Edge Functions as Deno.env.get('KEY')
#
# 4. For local development:
#    cp .env.example .env
#    # Edit .env with your local values
#    supabase functions serve --env-file .env
#
# ==============================================================================
# Security Reminders
# ==============================================================================
#
# ✅ DO:
# - Keep Service Role Key secret (never expose to client)
# - Rotate OpenAI API key regularly
# - Use different keys for dev/staging/production
# - Enable 2FA on OpenAI and WHOOP accounts
# - Monitor costs and set budget alerts
#
# ❌ DON'T:
# - Commit .env file to git
# - Share API keys via email or chat
# - Use production keys in development
# - Hardcode secrets in code
# - Disable RLS policies in production
#
# ==============================================================================
