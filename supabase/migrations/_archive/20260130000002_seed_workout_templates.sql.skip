                    {"id": "99999999-9999-9999-9999-999999999923", "name": "Jump Squats", "sequence": 2, "prescribed_sets": 4, "prescribed_reps": "30 seconds", "notes": "Explosive jump, soft landing"},
                    {"id": "99999999-9999-9999-9999-999999999924", "name": "Mountain Climbers", "sequence": 3, "prescribed_sets": 4, "prescribed_reps": "30 seconds", "notes": "Fast pace, core tight"},
                    {"id": "99999999-9999-9999-9999-999999999925", "name": "Jumping Lunges", "sequence": 4, "prescribed_sets": 4, "prescribed_reps": "30 seconds", "notes": "Switch legs in air"}
                ]
            },
            {
                "id": "99999999-9999-9999-9999-999999999931",
                "name": "Finisher",
                "block_type": "cardio",
                "sequence": 3,
                "exercises": [
