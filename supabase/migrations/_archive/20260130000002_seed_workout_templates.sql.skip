INSERT INTO system_workout_templates (
    id, name, description, category, difficulty,
    duration_minutes, exercises, tags, source_file, created_at
) VALUES (
    'b8c9d0e1-f2a3-1b2c-5d6e-7f8a9b0c1d2e',
    'Leg Day',
    'Comprehensive leg workout for the Push/Pull/Legs split. Targets quads, hamstrings, glutes, and calves.',
    'legs',
    'intermediate',
    55,
    '{
        "blocks": [
            {
                "id": "88888888-8888-8888-8888-888888888811",
                "name": "Warm-Up",
                "block_type": "cardio",
                "sequence": 1,
                "exercises": [
                    {"id": "88888888-8888-8888-8888-888888888812", "name": "Bike or Row", "sequence": 1, "prescribed_sets": 1, "prescribed_reps": "5 minutes", "notes": "Light effort, increase blood flow"},
                    {"id": "88888888-8888-8888-8888-888888888813", "name": "Leg Swings", "sequence": 2, "prescribed_sets": 2, "prescribed_reps": "15 each", "notes": "Front-back and side-side"},
                    {"id": "88888888-8888-8888-8888-888888888814", "name": "Goblet Squats", "sequence": 3, "prescribed_sets": 2, "prescribed_reps": "10", "notes": "Light weight, practice form"}
                ]
            },
            {
                "id": "88888888-8888-8888-8888-888888888821",
                "name": "Heavy Compound",
                "block_type": "strength",
                "sequence": 2,
                "exercises": [
                    {"id": "88888888-8888-8888-8888-888888888822", "name": "Back Squat", "sequence": 1, "prescribed_sets": 4, "prescribed_reps": "6-8", "notes": "Below parallel, drive through heels"},
                    {"id": "88888888-8888-8888-8888-888888888823", "name": "Romanian Deadlift", "sequence": 2, "prescribed_sets": 4, "prescribed_reps": "10", "notes": "Hip hinge, feel hamstring stretch"},
                    {"id": "88888888-8888-8888-8888-888888888824", "name": "Bulgarian Split Squat", "sequence": 3, "prescribed_sets": 3, "prescribed_reps": "10 each", "notes": "Rear foot elevated, control descent"}
                ]
            },
            {
                "id": "88888888-8888-8888-8888-888888888831",
                "name": "Accessory",
                "block_type": "functional",
                "sequence": 3,
                "exercises": [
                    {"id": "88888888-8888-8888-8888-888888888832", "name": "Leg Press", "sequence": 1, "prescribed_sets": 3, "prescribed_reps": "12", "notes": "Full range, dont lock knees"},
                    {"id": "88888888-8888-8888-8888-888888888833", "name": "Leg Curls", "sequence": 2, "prescribed_sets": 3, "prescribed_reps": "12", "notes": "Controlled tempo"},
                    {"id": "88888888-8888-8888-8888-888888888834", "name": "Walking Lunges", "sequence": 3, "prescribed_sets": 3, "prescribed_reps": "12 each", "notes": "Long stride, control balance"},
                    {"id": "88888888-8888-8888-8888-888888888835", "name": "Calf Raises", "sequence": 4, "prescribed_sets": 4, "prescribed_reps": "15", "notes": "Full stretch, pause at top"}
                ]
            }
        ]
    }'::jsonb,
    '{legs,squats,deadlifts,glutes,hamstrings,quads,calves,ppl,intermediate}',
    'build_325_seed.sql',
    NOW()
) ON CONFLICT (id) DO NOTHING;

