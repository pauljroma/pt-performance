    'cardio',
    'intermediate',
    35,
    '{
        "blocks": [
            {
                "id": "99999999-9999-9999-9999-999999999911",
                "name": "Warm-Up",
                "block_type": "cardio",
                "sequence": 1,
                "exercises": [
                    {"id": "99999999-9999-9999-9999-999999999912", "name": "Light Jog or Bike", "sequence": 1, "prescribed_sets": 1, "prescribed_reps": "3 minutes", "notes": "Easy pace to elevate heart rate"},
                    {"id": "99999999-9999-9999-9999-999999999913", "name": "Dynamic Stretches", "sequence": 2, "prescribed_sets": 1, "prescribed_reps": "2 minutes", "notes": "Leg swings, arm circles, torso twists"},
