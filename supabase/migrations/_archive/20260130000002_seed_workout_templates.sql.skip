INSERT INTO system_workout_templates (
    id, name, description, category, difficulty,
    duration_minutes, exercises, tags, source_file, created_at
) VALUES (
    'a7b8c9d0-e1f2-0a1b-4c5d-6e7f8a9b0c1d',
    'Pull Day',
    'Complete pull day targeting back and biceps. Part of a Push/Pull/Legs split routine.',
    'pull',
    'intermediate',
    50,
    '{
        "blocks": [
            {
                "id": "77777777-7777-7777-7777-777777777711",
                "name": "Warm-Up",
                "block_type": "dynamic_stretch",
                "sequence": 1,
                "exercises": [
                    {"id": "77777777-7777-7777-7777-777777777712", "name": "Band Face Pulls", "sequence": 1, "prescribed_sets": 2, "prescribed_reps": "15", "notes": "Light resistance, warm up rear delts"},
                    {"id": "77777777-7777-7777-7777-777777777713", "name": "Scapular Push-Ups", "sequence": 2, "prescribed_sets": 2, "prescribed_reps": "10", "notes": "Protract and retract shoulder blades"},
                    {"id": "77777777-7777-7777-7777-777777777714", "name": "Cat-Cow", "sequence": 3, "prescribed_sets": 1, "prescribed_reps": "10", "notes": "Mobilize thoracic spine"}
                ]
            },
            {
                "id": "77777777-7777-7777-7777-777777777721",
                "name": "Heavy Compound",
                "block_type": "pull",
                "sequence": 2,
                "exercises": [
                    {"id": "77777777-7777-7777-7777-777777777722", "name": "Deadlift", "sequence": 1, "prescribed_sets": 4, "prescribed_reps": "5", "notes": "Brace core, drive through heels"},
                    {"id": "77777777-7777-7777-7777-777777777723", "name": "Pull-Ups or Lat Pulldown", "sequence": 2, "prescribed_sets": 4, "prescribed_reps": "8-10", "notes": "Full range of motion"},
                    {"id": "77777777-7777-7777-7777-777777777724", "name": "Barbell Row", "sequence": 3, "prescribed_sets": 4, "prescribed_reps": "8", "notes": "Keep back flat, pull to lower chest"}
                ]
            },
            {
                "id": "77777777-7777-7777-7777-777777777731",
                "name": "Accessory",
                "block_type": "pull",
                "sequence": 3,
                "exercises": [
                    {"id": "77777777-7777-7777-7777-777777777732", "name": "Seated Cable Row", "sequence": 1, "prescribed_sets": 3, "prescribed_reps": "12", "notes": "Squeeze shoulder blades together"},
                    {"id": "77777777-7777-7777-7777-777777777733", "name": "Face Pulls", "sequence": 2, "prescribed_sets": 3, "prescribed_reps": "15", "notes": "External rotation at end"},
                    {"id": "77777777-7777-7777-7777-777777777734", "name": "Barbell Curls", "sequence": 3, "prescribed_sets": 3, "prescribed_reps": "10", "notes": "No swinging, controlled tempo"},
                    {"id": "77777777-7777-7777-7777-777777777735", "name": "Hammer Curls", "sequence": 4, "prescribed_sets": 3, "prescribed_reps": "12", "notes": "Targets brachialis and forearms"}
                ]
            }
        ]
    }'::jsonb,
    '{pull,back,biceps,deadlift,rows,lats,strength,ppl,intermediate}',
    'build_325_seed.sql',
    NOW()
) ON CONFLICT (id) DO NOTHING;

-- ============================================================================
-- 8. Leg Day
