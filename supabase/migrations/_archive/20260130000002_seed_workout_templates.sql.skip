    'intermediate',
    45,
    '{
        "blocks": [
            {
                "id": "11111111-1111-1111-1111-111111111111",
                "name": "Warm-Up",
                "block_type": "cardio",
                "sequence": 1,
                "exercises": [
                    {"id": "11111111-1111-1111-1111-111111111112", "name": "Arm Circles", "sequence": 1, "prescribed_sets": 2, "prescribed_reps": "20 each direction", "notes": "Start with small circles, gradually increase size"},
                    {"id": "11111111-1111-1111-1111-111111111113", "name": "Band Pull-Aparts", "sequence": 2, "prescribed_sets": 2, "prescribed_reps": "15", "notes": "Light resistance, focus on squeezing shoulder blades"},
                    {"id": "11111111-1111-1111-1111-111111111114", "name": "Push-Up to Downward Dog", "sequence": 3, "prescribed_sets": 2, "prescribed_reps": "8", "notes": "Dynamic movement to warm up shoulders and chest"}
                ]
            },
            {
                "id": "11111111-1111-1111-1111-111111111121",
                "name": "Strength - Push",
                "block_type": "push",
                "sequence": 2,
                "exercises": [
                    {"id": "11111111-1111-1111-1111-111111111122", "name": "Bench Press", "sequence": 1, "prescribed_sets": 4, "prescribed_reps": "8-10", "notes": "Control the descent, explosive press"},
                    {"id": "11111111-1111-1111-1111-111111111123", "name": "Overhead Press", "sequence": 2, "prescribed_sets": 3, "prescribed_reps": "10", "notes": "Keep core tight, press straight up"},
                    {"id": "11111111-1111-1111-1111-111111111124", "name": "Incline Dumbbell Press", "sequence": 3, "prescribed_sets": 3, "prescribed_reps": "12", "notes": "30-45 degree incline, full range of motion"}
                ]
            },
            {
                "id": "11111111-1111-1111-1111-111111111131",
                "name": "Strength - Pull",
                "block_type": "pull",
                "sequence": 3,
                "exercises": [
                    {"id": "11111111-1111-1111-1111-111111111132", "name": "Pull-Ups or Lat Pulldown", "sequence": 1, "prescribed_sets": 4, "prescribed_reps": "8-12", "notes": "Full extension at bottom, chin over bar at top"},
                    {"id": "11111111-1111-1111-1111-111111111133", "name": "Seated Cable Row", "sequence": 2, "prescribed_sets": 3, "prescribed_reps": "12", "notes": "Squeeze shoulder blades together at peak contraction"},
                    {"id": "11111111-1111-1111-1111-111111111134", "name": "Face Pulls", "sequence": 3, "prescribed_sets": 3, "prescribed_reps": "15", "notes": "High pull to face, external rotation at end"}
                ]
            },
            {
                "id": "11111111-1111-1111-1111-111111111141",
                "name": "Accessory Work",
                "block_type": "functional",
                "sequence": 4,
                "exercises": [
                    {"id": "11111111-1111-1111-1111-111111111142", "name": "Bicep Curls", "sequence": 1, "prescribed_sets": 3, "prescribed_reps": "12", "notes": "Controlled tempo, no swinging"},
                    {"id": "11111111-1111-1111-1111-111111111143", "name": "Tricep Pushdowns", "sequence": 2, "prescribed_sets": 3, "prescribed_reps": "12", "notes": "Keep elbows pinned to sides"},
                    {"id": "11111111-1111-1111-1111-111111111144", "name": "Lateral Raises", "sequence": 3, "prescribed_sets": 3, "prescribed_reps": "15", "notes": "Light weight, control throughout"}
                ]
            }
        ]
