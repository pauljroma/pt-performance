-- ============================================================================
-- 10. Beginner Full Body
-- ============================================================================
INSERT INTO system_workout_templates (
    id, name, description, category, difficulty,
    duration_minutes, exercises, tags, source_file, created_at
) VALUES (
    'd0e1f2a3-b4c5-3d4e-7f8a-9b0c1d2e3f4a',
    'Beginner Full Body',
    'Perfect starting point for fitness beginners. Covers all major movement patterns with focus on form and building a foundation.',
    'full_body',
    'beginner',
    40,
    '{
        "blocks": [
            {
                "id": "aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaa011",
                "name": "Warm-Up",
                "block_type": "cardio",
                "sequence": 1,
                "exercises": [
                    {"id": "aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaa012", "name": "March in Place", "sequence": 1, "prescribed_sets": 1, "prescribed_reps": "2 minutes", "notes": "Get moving, elevate heart rate"},
                    {"id": "aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaa013", "name": "Arm Circles", "sequence": 2, "prescribed_sets": 2, "prescribed_reps": "10 each direction", "notes": "Loosen up shoulders"},
                    {"id": "aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaa014", "name": "Bodyweight Squats", "sequence": 3, "prescribed_sets": 2, "prescribed_reps": "10", "notes": "Practice form, sit back into heels"}
                ]
            },
            {
                "id": "aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaa021",
                "name": "Lower Body",
                "block_type": "strength",
                "sequence": 2,
                "exercises": [
                    {"id": "aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaa022", "name": "Goblet Squats", "sequence": 1, "prescribed_sets": 3, "prescribed_reps": "10", "notes": "Hold weight at chest, squat to depth you can control"},
                    {"id": "aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaa023", "name": "Dumbbell Romanian Deadlift", "sequence": 2, "prescribed_sets": 3, "prescribed_reps": "10", "notes": "Light weight, hinge at hips, slight knee bend"},
                    {"id": "aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaa024", "name": "Reverse Lunges", "sequence": 3, "prescribed_sets": 2, "prescribed_reps": "8 each", "notes": "Step back, lower with control"}
                ]
            },
            {
                "id": "aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaa031",
                "name": "Upper Body",
                "block_type": "strength",
                "sequence": 3,
                "exercises": [
                    {"id": "aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaa032", "name": "Push-Ups (or Modified)", "sequence": 1, "prescribed_sets": 3, "prescribed_reps": "8-10", "notes": "Use knees if needed, maintain plank position"},
                    {"id": "aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaa033", "name": "Dumbbell Rows", "sequence": 2, "prescribed_sets": 3, "prescribed_reps": "10 each", "notes": "Support on bench, pull to hip"},
                    {"id": "aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaa034", "name": "Dumbbell Shoulder Press", "sequence": 3, "prescribed_sets": 2, "prescribed_reps": "10", "notes": "Seated or standing, press straight up"}
                ]
            },
            {
                "id": "aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaa041",
                "name": "Core & Finish",
                "block_type": "functional",
                "sequence": 4,
                "exercises": [
                    {"id": "aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaa042", "name": "Plank", "sequence": 1, "prescribed_sets": 3, "prescribed_reps": "20-30 seconds", "notes": "Keep body straight, don't let hips sag"},
                    {"id": "aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaa043", "name": "Dead Bug", "sequence": 2, "prescribed_sets": 2, "prescribed_reps": "8 each", "notes": "Lower back stays pressed to floor"},
                    {"id": "aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaa044", "name": "Light Stretching", "sequence": 3, "prescribed_sets": 1, "prescribed_reps": "5 minutes", "notes": "Stretch all major muscle groups"}
                ]
            }
        ]
    }'::jsonb,
    '{beginner,full_body,foundation,basic,newbie,starter,easy}',
    'build_325_seed.sql',
    NOW()
) ON CONFLICT (id) DO NOTHING;

-- ============================================================================
-- VERIFICATION
-- ============================================================================

DO $$
DECLARE
    v_count INTEGER;
BEGIN
    SELECT COUNT(*) INTO v_count
    FROM system_workout_templates
    WHERE source_file = 'build_325_seed.sql';

    RAISE NOTICE 'Build 325 seeded % workout templates', v_count;

    IF v_count < 10 THEN
        RAISE WARNING 'Expected 10 templates, only % were inserted (some may have already existed)', v_count;
    END IF;
END $$;

COMMIT;
