# PT Performance Docker Environment Variables
# Copy this file to .env and replace placeholder values with secure passwords
#
# Generate secure passwords with: openssl rand -base64 32

# PostgreSQL Main Database
POSTGRES_PASSWORD=CHANGE_ME_secure_password_here

# PGVector Database
PGVECTOR_PASSWORD=CHANGE_ME_secure_password_here

# Neo4j Graph Database
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGE_ME_secure_password_here

# N8N Workflow Automation
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME_secure_password_here
