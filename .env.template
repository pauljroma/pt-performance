# PT Performance Environment Variables Template
# Copy this to .env and fill in your values
# NEVER commit .env to version control!

# ===========================================
# DATABASE CREDENTIALS
# ===========================================
POSTGRES_PASSWORD=your_secure_postgres_password_here
PGVECTOR_PASSWORD=your_secure_pgvector_password_here

# ===========================================
# NEO4J CREDENTIALS
# ===========================================
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_secure_neo4j_password_here

# ===========================================
# N8N CREDENTIALS (Workflow Automation)
# ===========================================
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=your_secure_n8n_password_here

# ===========================================
# SUPABASE (if running locally)
# ===========================================
# SUPABASE_URL=http://localhost:54321
# SUPABASE_ANON_KEY=your_anon_key
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ===========================================
# APPLE (StoreKit / In-App Purchases)
# ===========================================
# APPLE_SHARED_SECRET=your_apple_shared_secret

# ===========================================
# LINEAR (Issue Tracking)
# ===========================================
# LINEAR_API_KEY=lin_api_xxx

# ===========================================
# WHOOP (Wearable Integration)
# ===========================================
# WHOOP_CLIENT_ID=xxx
# WHOOP_CLIENT_SECRET=xxx
