default_platform(:ios)

platform :ios do
  desc "Push a new beta build to TestFlight"
  lane :beta do
    # Set up App Store Connect API Key
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
      is_key_content_base64: true
    )

    # Create app in App Store Connect if it doesn't exist
    produce(
      username: ENV["APPLE_ID"],
      app_identifier: "com.ptperformance.app",
      app_name: "PT Performance",
      language: "English",
      app_version: "1.0",
      sku: "ptperformance-001",
      skip_itc: false
    )

    # Increment build number based on TestFlight
    increment_build_number(
      xcodeproj: "PTPerformance.xcodeproj",
      build_number: latest_testflight_build_number(
        api_key: api_key,
        initial_build_number: 1
      ) + 1
    )

    # Build the app with automatic signing
    build_app(
      scheme: "PTPerformance",
      export_method: "app-store",
      export_options: {
        signingStyle: "automatic",
        teamID: ENV["FASTLANE_TEAM_ID"]
      }
    )

    # Upload to TestFlight
    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      distribute_external: false
    )
  end
end
