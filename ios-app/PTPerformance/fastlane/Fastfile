default_platform(:ios)

platform :ios do
  desc "Push a new beta build to TestFlight"
  lane :beta do
    # Increment build number
    increment_build_number(
      xcodeproj: "PTPerformance.xcodeproj"
    )

    # Build with automatic code signing
    build_app(
      scheme: "PTPerformance",
      export_method: "app-store",
      xcargs: "-allowProvisioningUpdates DEVELOPMENT_TEAM=#{ENV['FASTLANE_TEAM_ID']}"
    )

    # Upload to TestFlight using Apple ID authentication
    upload_to_testflight(
      username: ENV["APPLE_ID"],
      skip_waiting_for_build_processing: true,
      distribute_external: false
    )
  end
end
