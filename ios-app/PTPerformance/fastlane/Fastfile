default_platform(:ios)

platform :ios do
  desc "Push a new beta build to TestFlight"
  lane :beta do
    # Increment build number
    increment_build_number(
      build_number: 7,
      xcodeproj: "PTPerformance.xcodeproj"
    )

    # Set up App Store Connect API key
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
      is_key_content_base64: true
    )

    # Get certificates and provisioning profiles using match
    match(
      type: "appstore",
      api_key: api_key,
      readonly: false,
      app_identifier: "com.ptperformance.app"
    )

    # Build with match signing
    build_app(
      scheme: "PTPerformance",
      export_method: "app-store",
      export_options: {
        method: "app-store",
        provisioningProfiles: {
          "com.ptperformance.app" => "match AppStore com.ptperformance.app"
        }
      },
      buildlog_path: "./fastlane/logs",
      xcargs: "-allowProvisioningUpdates",
      archive_path: "./build/PTPerformance.xcarchive"
    )

    # Upload to TestFlight using App Store Connect API
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
      is_key_content_base64: true
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      distribute_external: false
    )
  end
end
