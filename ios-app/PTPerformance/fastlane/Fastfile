default_platform(:ios)

platform :ios do
  desc "Push a new beta build to TestFlight"
  lane :beta do
    # Set up App Store Connect API Key
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
      is_key_content_base64: true
    )

    # Set up code signing with Match
    match(
      type: "appstore",
      api_key: api_key,
      readonly: false
    )

    # Increment build number
    increment_build_number(
      xcodeproj: "PTPerformance.xcodeproj"
    )

    # Build and sign the app with explicit certificate/profile from Match
    build_app(
      scheme: "PTPerformance",
      export_method: "app-store",
      xcargs: "CODE_SIGN_STYLE=Manual DEVELOPMENT_TEAM=#{ENV['FASTLANE_TEAM_ID']} CODE_SIGN_IDENTITY='Apple Distribution' PROVISIONING_PROFILE_SPECIFIER='match AppStore Romatechv100'",
      export_options: {
        method: "app-store",
        provisioningProfiles: {
          "Romatechv100" => "match AppStore Romatechv100"
        },
        signingStyle: "manual",
        teamID: ENV["FASTLANE_TEAM_ID"]
      }
    )

    # Upload to TestFlight
    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      distribute_external: false
    )
  end
end
