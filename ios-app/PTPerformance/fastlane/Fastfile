default_platform(:ios)

platform :ios do
  desc "Push a new beta build to TestFlight"
  lane :beta do
    # Set up App Store Connect API Key
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
      is_key_content_base64: true
    )

    # Increment build number
    increment_build_number(
      xcodeproj: "PTPerformance.xcodeproj"
    )

    # Build the app (signing handled during export for CI/CD)
    build_app(
      scheme: "PTPerformance",
      export_method: "app-store",
      export_team_id: ENV["FASTLANE_TEAM_ID"],
      xcargs: "CODE_SIGN_IDENTITY='' CODE_SIGNING_REQUIRED=NO CODE_SIGNING_ALLOWED=NO",
      export_options: {
        method: "app-store",
        teamID: ENV["FASTLANE_TEAM_ID"],
        signingStyle: "automatic",
        signingCertificate: "Apple Distribution"
      }
    )

    # Upload to TestFlight
    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      distribute_external: false
    )
  end
end
