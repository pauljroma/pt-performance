default_platform(:ios)

platform :ios do
  desc "Push a new beta build to TestFlight"
  lane :beta do
    # Set up App Store Connect API Key
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
      is_key_content_base64: true
    )

    # Set up code signing with Match
    match(
      type: "appstore",
      api_key: api_key,
      readonly: false,
      git_url: "https://github.com/pauljroma/apple-certificates.git",
      git_basic_authorization: ENV["MATCH_GIT_BASIC_AUTHORIZATION"],
      app_identifier: "com.ptperformance.app"
    )

    # Configure code signing settings to fix Swift package signing issues
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "PTPerformance.xcodeproj",
      targets: ["PTPerformance"],
      code_sign_identity: "Apple Distribution",
      profile_name: "match AppStore com.ptperformance.app",
      bundle_identifier: "com.ptperformance.app"
    )

    # Set Swift packages to use automatic signing (they don't support provisioning profiles)
    update_code_signing_settings(
      use_automatic_signing: true,
      path: "PTPerformance.xcodeproj",
      targets: ["swift-crypto_Crypto", "Supabase"],
      code_sign_identity: "Apple Development"
    )

    # Increment build number
    increment_build_number(
      xcodeproj: "PTPerformance.xcodeproj"
    )

    # Build and sign the app
    build_app(
      scheme: "PTPerformance",
      export_method: "app-store",
      export_options: {
        method: "app-store",
        provisioningProfiles: {
          "com.ptperformance.app" => "match AppStore com.ptperformance.app"
        },
        signingStyle: "manual",
        teamID: ENV["FASTLANE_TEAM_ID"]
      }
    )

    # Upload to TestFlight
    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      distribute_external: false
    )
  end
end
