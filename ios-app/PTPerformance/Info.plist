<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>BGTaskSchedulerPermittedIdentifiers</key>
	<array>
		<string>com.getmodus.timer.background</string>
		<string>com.getmodus.health-sync</string>
		<string>com.getmodus.health-processing</string>
	</array>
	<key>CFBundleDisplayName</key>
	<string>Modus</string>
	<key>CFBundleIconName</key>
	<string>AppIcon</string>
	<key>CFBundleName</key>
	<string>Modus</string>
	<key>CFBundleShortVersionString</key>
	<string>1.0.0</string>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.getmodus.app</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>modus</string>
			</array>
		</dict>
	</array>
	<key>CFBundleVersion</key>
	<string>427</string>
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>NSCalendarsUsageDescription</key>
	<string>Modus syncs your workouts to your calendar so you never miss a session and can import game schedules to automatically adjust your training.</string>
	<key>NSCameraUsageDescription</key>
	<string>Modus needs camera access to record exercise form check videos that you can share with your physical therapist for technique feedback and guidance.</string>
	<key>NSHealthShareUsageDescription</key>
	<string>Modus uses your HRV, sleep, and heart rate data to personalize recovery recommendations and automatically adjust your workout intensity based on your readiness.</string>
	<key>NSHealthUpdateUsageDescription</key>
	<string>Modus can save your workout data to Apple Health to help you track your fitness progress across all your health apps.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Modus needs microphone access to record audio with your exercise videos so your therapist can hear your questions and provide better feedback.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Modus needs photo library access to let you select and share exercise videos and images with your physical therapist.</string>
	<key>NSSiriUsageDescription</key>
	<string>Modus uses Siri to let you start workouts, log exercises, and check your readiness score hands-free while training.</string>
	<key>NSUserActivityTypes</key>
	<array>
		<string>StartWorkoutIntent</string>
		<string>LogExerciseIntent</string>
		<string>QuickLogIntent</string>
		<string>CheckReadinessIntent</string>
		<string>LogReadinessIntent</string>
		<string>ViewProgressIntent</string>
		<string>StartRestTimerIntent</string>
	</array>
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<false/>
		<key>UISceneConfigurations</key>
		<dict>
			<key>UIWindowSceneSessionRoleApplication</key>
			<array>
				<dict>
					<key>UISceneConfigurationName</key>
					<string>Default Configuration</string>
					<key>UISceneDelegateClassName</key>
					<string>$(PRODUCT_MODULE_NAME).SceneDelegate</string>
				</dict>
			</array>
		</dict>
	</dict>
	<key>UIBackgroundModes</key>
	<array>
		<string>fetch</string>
		<string>processing</string>
	</array>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIRequiresFullScreen</key>
	<false/>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
</dict>
</plist>
