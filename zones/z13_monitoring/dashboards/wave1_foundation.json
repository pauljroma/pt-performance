{
  "dashboard": {
    "title": "Wave 1 Foundation - Rust Primitives & Tier Router",
    "description": "Comprehensive monitoring for Wave 1 components: Rust primitives, Tier router, and performance metrics",
    "tags": ["wave1", "rust", "tier-router", "performance"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "10s",
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "timepicker": {
      "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h"]
    },
    "annotations": {
      "list": [
        {
          "name": "Deployments",
          "datasource": "-- Grafana --",
          "enable": true,
          "iconColor": "green",
          "tags": ["deployment"]
        },
        {
          "name": "Alerts",
          "datasource": "-- Grafana --",
          "enable": true,
          "iconColor": "red",
          "tags": ["alert"]
        }
      ]
    },
    "panels": [
      {
        "id": 1,
        "title": "System Health Overview",
        "type": "stat",
        "gridPos": {"x": 0, "y": 0, "w": 24, "h": 4},
        "targets": [
          {
            "expr": "wave1_system_health{component='overall'}",
            "legendFormat": "Overall Health",
            "refId": "A"
          }
        ],
        "options": {
          "graphMode": "area",
          "colorMode": "background",
          "justifyMode": "auto",
          "textMode": "auto",
          "orientation": "horizontal"
        },
        "fieldConfig": {
          "defaults": {
            "mappings": [
              {"type": "value", "value": "1", "text": "Healthy", "color": "green"},
              {"type": "value", "value": "0.5", "text": "Degraded", "color": "yellow"},
              {"type": "value", "value": "0", "text": "Critical", "color": "red"}
            ],
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "red"},
                {"value": 0.5, "color": "yellow"},
                {"value": 1, "color": "green"}
              ]
            }
          }
        }
      },
      {
        "id": 2,
        "title": "Rust Primitives - Latency",
        "type": "graph",
        "gridPos": {"x": 0, "y": 4, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "histogram_quantile(0.50, rate(rust_primitives_latency_bucket[5m]))",
            "legendFormat": "P50",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.95, rate(rust_primitives_latency_bucket[5m]))",
            "legendFormat": "P95",
            "refId": "B"
          },
          {
            "expr": "histogram_quantile(0.99, rate(rust_primitives_latency_bucket[5m]))",
            "legendFormat": "P99",
            "refId": "C"
          }
        ],
        "yaxes": [
          {
            "label": "Latency (ms)",
            "format": "ms",
            "min": 0,
            "max": null
          }
        ],
        "alert": {
          "name": "Rust Primitives High Latency",
          "message": "Rust primitives P95 latency exceeded 0.1ms threshold",
          "conditions": [
            {
              "evaluator": {"type": "gt", "params": [0.1]},
              "operator": {"type": "and"},
              "query": {"params": ["B", "5m", "now"]},
              "reducer": {"type": "avg"},
              "type": "query"
            }
          ],
          "executionErrorState": "alerting",
          "frequency": "1m",
          "for": "2m",
          "noDataState": "no_data"
        },
        "thresholds": [
          {"value": 0.1, "colorMode": "critical", "op": "gt", "fill": true, "line": true}
        ]
      },
      {
        "id": 3,
        "title": "Rust Primitives - Fallback Rate",
        "type": "graph",
        "gridPos": {"x": 12, "y": 4, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "rate(rust_primitives_fallback_total[5m]) / rate(rust_primitives_requests_total[5m]) * 100",
            "legendFormat": "Fallback Rate %",
            "refId": "A"
          }
        ],
        "yaxes": [
          {
            "label": "Fallback Rate (%)",
            "format": "percent",
            "min": 0,
            "max": 5
          }
        ],
        "alert": {
          "name": "Rust Fallback Rate High",
          "message": "Rust fallback rate exceeded 1% threshold - check Rust service availability",
          "conditions": [
            {
              "evaluator": {"type": "gt", "params": [1]},
              "operator": {"type": "and"},
              "query": {"params": ["A", "5m", "now"]},
              "reducer": {"type": "avg"},
              "type": "query"
            }
          ],
          "executionErrorState": "alerting",
          "frequency": "1m",
          "for": "3m",
          "noDataState": "no_data"
        },
        "thresholds": [
          {"value": 0.5, "colorMode": "warning", "op": "gt", "fill": false, "line": true},
          {"value": 1.0, "colorMode": "critical", "op": "gt", "fill": true, "line": true}
        ]
      },
      {
        "id": 4,
        "title": "Rust Primitives - Cache Performance",
        "type": "graph",
        "gridPos": {"x": 0, "y": 12, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "rate(rust_primitives_cache_hits[5m]) / (rate(rust_primitives_cache_hits[5m]) + rate(rust_primitives_cache_misses[5m])) * 100",
            "legendFormat": "Cache Hit Rate %",
            "refId": "A"
          },
          {
            "expr": "rust_primitives_cache_size",
            "legendFormat": "Cache Size",
            "refId": "B"
          }
        ],
        "yaxes": [
          {
            "label": "Hit Rate (%)",
            "format": "percent",
            "min": 0,
            "max": 100
          },
          {
            "label": "Cache Size",
            "format": "short"
          }
        ],
        "alert": {
          "name": "Rust Cache Hit Rate Low",
          "message": "Cache hit rate dropped below 50% - consider reviewing cache configuration",
          "conditions": [
            {
              "evaluator": {"type": "lt", "params": [50]},
              "operator": {"type": "and"},
              "query": {"params": ["A", "5m", "now"]},
              "reducer": {"type": "avg"},
              "type": "query"
            }
          ],
          "executionErrorState": "alerting",
          "frequency": "1m",
          "for": "5m",
          "noDataState": "no_data"
        },
        "thresholds": [
          {"value": 50, "colorMode": "critical", "op": "lt", "fill": true, "line": true},
          {"value": 60, "colorMode": "warning", "op": "lt", "fill": false, "line": true}
        ]
      },
      {
        "id": 5,
        "title": "Rust Primitives - Throughput & Errors",
        "type": "graph",
        "gridPos": {"x": 12, "y": 12, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "rate(rust_primitives_requests_total[1m]) * 60",
            "legendFormat": "Requests/min",
            "refId": "A"
          },
          {
            "expr": "rate(rust_primitives_errors_total[1m]) * 60",
            "legendFormat": "Errors/min",
            "refId": "B"
          }
        ],
        "yaxes": [
          {
            "label": "Operations/min",
            "format": "short",
            "min": 0
          }
        ],
        "alert": {
          "name": "Rust Primitives Error Rate",
          "message": "Rust primitives error rate exceeded 0 - investigate errors immediately",
          "conditions": [
            {
              "evaluator": {"type": "gt", "params": [0]},
              "operator": {"type": "and"},
              "query": {"params": ["B", "5m", "now"]},
              "reducer": {"type": "avg"},
              "type": "query"
            }
          ],
          "executionErrorState": "alerting",
          "frequency": "1m",
          "for": "2m",
          "noDataState": "no_data"
        }
      },
      {
        "id": 6,
        "title": "Tier Router - Routing Overhead",
        "type": "graph",
        "gridPos": {"x": 0, "y": 20, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "histogram_quantile(0.50, rate(tier_router_overhead_bucket[5m]))",
            "legendFormat": "P50",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.95, rate(tier_router_overhead_bucket[5m]))",
            "legendFormat": "P95",
            "refId": "B"
          },
          {
            "expr": "histogram_quantile(0.99, rate(tier_router_overhead_bucket[5m]))",
            "legendFormat": "P99",
            "refId": "C"
          }
        ],
        "yaxes": [
          {
            "label": "Overhead (ms)",
            "format": "ms",
            "min": 0,
            "max": 2
          }
        ],
        "alert": {
          "name": "Tier Router High Overhead",
          "message": "Tier router overhead exceeded 1ms threshold - review routing logic",
          "conditions": [
            {
              "evaluator": {"type": "gt", "params": [1]},
              "operator": {"type": "and"},
              "query": {"params": ["B", "5m", "now"]},
              "reducer": {"type": "avg"},
              "type": "query"
            }
          ],
          "executionErrorState": "alerting",
          "frequency": "1m",
          "for": "3m",
          "noDataState": "no_data"
        },
        "thresholds": [
          {"value": 0.6, "colorMode": "warning", "op": "gt", "fill": false, "line": true},
          {"value": 1.0, "colorMode": "critical", "op": "gt", "fill": true, "line": true}
        ]
      },
      {
        "id": 7,
        "title": "Tier Router - Tier Distribution",
        "type": "piechart",
        "gridPos": {"x": 12, "y": 20, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "sum by (tier) (rate(tier_router_queries_by_tier[5m]))",
            "legendFormat": "{{tier}}",
            "refId": "A"
          }
        ],
        "options": {
          "legend": {
            "displayMode": "table",
            "placement": "right",
            "values": ["value", "percent"]
          },
          "pieType": "donut",
          "tooltip": {
            "mode": "single"
          }
        },
        "fieldConfig": {
          "defaults": {
            "custom": {
              "hideFrom": {
                "tooltip": false,
                "viz": false,
                "legend": false
              }
            },
            "mappings": [],
            "color": {
              "mode": "palette-classic"
            }
          },
          "overrides": [
            {
              "matcher": {"id": "byName", "options": "master_tables"},
              "properties": [{"id": "color", "value": {"fixedColor": "blue", "mode": "fixed"}}]
            },
            {
              "matcher": {"id": "byName", "options": "pgvector"},
              "properties": [{"id": "color", "value": {"fixedColor": "green", "mode": "fixed"}}]
            },
            {
              "matcher": {"id": "byName", "options": "minio"},
              "properties": [{"id": "color", "value": {"fixedColor": "orange", "mode": "fixed"}}]
            },
            {
              "matcher": {"id": "byName", "options": "athena"},
              "properties": [{"id": "color", "value": {"fixedColor": "purple", "mode": "fixed"}}]
            }
          ]
        }
      },
      {
        "id": 8,
        "title": "Tier Router - Routing Percentage",
        "type": "stat",
        "gridPos": {"x": 0, "y": 28, "w": 8, "h": 4},
        "targets": [
          {
            "expr": "(sum(rate(tier_router_queries_by_tier{tier!='master_tables'}[5m])) / sum(rate(tier_router_queries_by_tier[5m]))) * 100",
            "legendFormat": "Non-Master Routing %",
            "refId": "A"
          }
        ],
        "options": {
          "graphMode": "area",
          "colorMode": "value",
          "textMode": "value_and_name",
          "orientation": "horizontal"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "decimals": 1,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "red"},
                {"value": 30, "color": "yellow"},
                {"value": 42, "color": "green"}
              ]
            }
          }
        }
      },
      {
        "id": 9,
        "title": "Tier Router - Fallback Rate",
        "type": "stat",
        "gridPos": {"x": 8, "y": 28, "w": 8, "h": 4},
        "targets": [
          {
            "expr": "(rate(tier_router_fallback_total[5m]) / rate(tier_router_requests_total[5m])) * 100",
            "legendFormat": "Fallback Rate %",
            "refId": "A"
          }
        ],
        "options": {
          "graphMode": "area",
          "colorMode": "value",
          "textMode": "value_and_name",
          "orientation": "horizontal"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "decimals": 2,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 0.5, "color": "yellow"},
                {"value": 1, "color": "red"}
              ]
            }
          }
        }
      },
      {
        "id": 10,
        "title": "Tier Router - Classification Speed",
        "type": "stat",
        "gridPos": {"x": 16, "y": 28, "w": 8, "h": 4},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(tier_router_classification_duration_bucket[5m]))",
            "legendFormat": "Classification P95",
            "refId": "A"
          }
        ],
        "options": {
          "graphMode": "area",
          "colorMode": "value",
          "textMode": "value_and_name",
          "orientation": "horizontal"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "ms",
            "decimals": 3,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 0.15, "color": "yellow"},
                {"value": 0.23, "color": "red"}
              ]
            }
          }
        }
      },
      {
        "id": 11,
        "title": "End-to-End Performance - Latency",
        "type": "graph",
        "gridPos": {"x": 0, "y": 32, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "histogram_quantile(0.50, rate(wave1_end_to_end_latency_bucket[5m]))",
            "legendFormat": "P50",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.95, rate(wave1_end_to_end_latency_bucket[5m]))",
            "legendFormat": "P95",
            "refId": "B"
          },
          {
            "expr": "histogram_quantile(0.99, rate(wave1_end_to_end_latency_bucket[5m]))",
            "legendFormat": "P99",
            "refId": "C"
          }
        ],
        "yaxes": [
          {
            "label": "Latency (ms)",
            "format": "ms",
            "min": 0,
            "max": 5
          }
        ],
        "alert": {
          "name": "End-to-End High Latency",
          "message": "End-to-end P95 latency exceeded 2ms threshold - check system health",
          "conditions": [
            {
              "evaluator": {"type": "gt", "params": [2]},
              "operator": {"type": "and"},
              "query": {"params": ["B", "5m", "now"]},
              "reducer": {"type": "avg"},
              "type": "query"
            }
          ],
          "executionErrorState": "alerting",
          "frequency": "1m",
          "for": "3m",
          "noDataState": "no_data"
        },
        "thresholds": [
          {"value": 2, "colorMode": "warning", "op": "gt", "fill": false, "line": true},
          {"value": 5, "colorMode": "critical", "op": "gt", "fill": true, "line": true}
        ]
      },
      {
        "id": 12,
        "title": "System Performance - Throughput",
        "type": "graph",
        "gridPos": {"x": 12, "y": 32, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "rate(wave1_queries_total[1m]) * 60",
            "legendFormat": "Queries/min",
            "refId": "A"
          },
          {
            "expr": "rate(wave1_queries_total[5m]) * 60",
            "legendFormat": "Queries/min (5m avg)",
            "refId": "B"
          }
        ],
        "yaxes": [
          {
            "label": "Queries/min",
            "format": "short",
            "min": 0
          }
        ],
        "alert": {
          "name": "Low Throughput Warning",
          "message": "Query throughput dropped below expected levels - investigate performance degradation",
          "conditions": [
            {
              "evaluator": {"type": "lt", "params": [30000]},
              "operator": {"type": "and"},
              "query": {"params": ["A", "5m", "now"]},
              "reducer": {"type": "avg"},
              "type": "query"
            }
          ],
          "executionErrorState": "alerting",
          "frequency": "1m",
          "for": "5m",
          "noDataState": "no_data"
        },
        "thresholds": [
          {"value": 30000, "colorMode": "warning", "op": "lt", "fill": false, "line": true}
        ]
      },
      {
        "id": 13,
        "title": "System Performance - Memory Usage",
        "type": "graph",
        "gridPos": {"x": 0, "y": 40, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "process_resident_memory_bytes{job='wave1'}",
            "legendFormat": "Memory Usage (bytes)",
            "refId": "A"
          },
          {
            "expr": "rust_primitives_cache_memory_bytes",
            "legendFormat": "Cache Memory (bytes)",
            "refId": "B"
          }
        ],
        "yaxes": [
          {
            "label": "Memory",
            "format": "bytes",
            "min": 0
          }
        ],
        "alert": {
          "name": "High Memory Usage",
          "message": "Memory usage exceeded 500MB - potential memory leak or cache bloat",
          "conditions": [
            {
              "evaluator": {"type": "gt", "params": [524288000]},
              "operator": {"type": "and"},
              "query": {"params": ["A", "5m", "now"]},
              "reducer": {"type": "avg"},
              "type": "query"
            }
          ],
          "executionErrorState": "alerting",
          "frequency": "1m",
          "for": "10m",
          "noDataState": "no_data"
        },
        "thresholds": [
          {"value": 524288000, "colorMode": "critical", "op": "gt", "fill": true, "line": true}
        ]
      },
      {
        "id": 14,
        "title": "System Performance - Error Rate",
        "type": "graph",
        "gridPos": {"x": 12, "y": 40, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "(rate(wave1_errors_total[5m]) / rate(wave1_queries_total[5m])) * 100",
            "legendFormat": "Error Rate %",
            "refId": "A"
          },
          {
            "expr": "rate(wave1_errors_total{severity='critical'}[5m]) * 60",
            "legendFormat": "Critical Errors/min",
            "refId": "B"
          }
        ],
        "yaxes": [
          {
            "label": "Error Rate (%)",
            "format": "percent",
            "min": 0
          },
          {
            "label": "Errors/min",
            "format": "short"
          }
        ],
        "alert": {
          "name": "High Error Rate",
          "message": "Error rate exceeded 1% - investigate errors immediately",
          "conditions": [
            {
              "evaluator": {"type": "gt", "params": [1]},
              "operator": {"type": "and"},
              "query": {"params": ["A", "5m", "now"]},
              "reducer": {"type": "avg"},
              "type": "query"
            }
          ],
          "executionErrorState": "alerting",
          "frequency": "1m",
          "for": "2m",
          "noDataState": "no_data"
        },
        "thresholds": [
          {"value": 0.1, "colorMode": "warning", "op": "gt", "fill": false, "line": true},
          {"value": 1, "colorMode": "critical", "op": "gt", "fill": true, "line": true}
        ]
      },
      {
        "id": 15,
        "title": "Alert Status Summary",
        "type": "table",
        "gridPos": {"x": 0, "y": 48, "w": 24, "h": 6},
        "targets": [
          {
            "expr": "ALERTS{job='wave1'}",
            "legendFormat": "",
            "refId": "A",
            "instant": true
          }
        ],
        "options": {
          "showHeader": true,
          "sortBy": [{"displayName": "State", "desc": false}]
        },
        "fieldConfig": {
          "defaults": {
            "custom": {
              "align": "left",
              "filterable": true
            }
          },
          "overrides": [
            {
              "matcher": {"id": "byName", "options": "alertstate"},
              "properties": [
                {
                  "id": "custom.displayMode",
                  "value": "color-background"
                },
                {
                  "id": "mappings",
                  "value": [
                    {"type": "value", "value": "firing", "text": "FIRING", "color": "red"},
                    {"type": "value", "value": "pending", "text": "PENDING", "color": "yellow"},
                    {"type": "value", "value": "inactive", "text": "OK", "color": "green"}
                  ]
                }
              ]
            }
          ]
        }
      },
      {
        "id": 16,
        "title": "Performance Baseline Comparison",
        "type": "table",
        "gridPos": {"x": 0, "y": 54, "w": 24, "h": 8},
        "targets": [
          {
            "expr": "wave1_performance_baseline",
            "legendFormat": "",
            "refId": "A",
            "instant": true,
            "format": "table"
          }
        ],
        "options": {
          "showHeader": true,
          "sortBy": [{"displayName": "Metric", "desc": false}]
        },
        "fieldConfig": {
          "defaults": {
            "custom": {
              "align": "left",
              "filterable": true
            }
          },
          "overrides": [
            {
              "matcher": {"id": "byName", "options": "status"},
              "properties": [
                {
                  "id": "custom.displayMode",
                  "value": "color-background"
                },
                {
                  "id": "mappings",
                  "value": [
                    {"type": "value", "value": "exceeds", "text": "EXCEEDS", "color": "green"},
                    {"type": "value", "value": "meets", "text": "MEETS", "color": "blue"},
                    {"type": "value", "value": "below", "text": "BELOW", "color": "red"}
                  ]
                }
              ]
            }
          ]
        },
        "transformations": [
          {
            "id": "organize",
            "options": {
              "excludeByName": {},
              "indexByName": {
                "metric": 0,
                "target": 1,
                "achieved": 2,
                "status": 3,
                "margin": 4
              }
            }
          }
        ]
      }
    ],
    "templating": {
      "list": [
        {
          "name": "environment",
          "type": "custom",
          "multi": false,
          "options": [
            {"text": "Production", "value": "prod", "selected": true},
            {"text": "Staging", "value": "staging", "selected": false},
            {"text": "Development", "value": "dev", "selected": false}
          ],
          "current": {"text": "Production", "value": "prod"}
        },
        {
          "name": "component",
          "type": "custom",
          "multi": true,
          "includeAll": true,
          "options": [
            {"text": "Rust Primitives", "value": "rust_primitives", "selected": true},
            {"text": "Tier Router", "value": "tier_router", "selected": true},
            {"text": "End-to-End", "value": "end_to_end", "selected": true}
          ],
          "current": {"text": "All", "value": "$__all"}
        }
      ]
    }
  },
