{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://tool-chain/task-schema/v1",
  "title": "TaskEnvelope",
  "description": "Universal wire format for agent task dispatch. Every orchestrator (develop-cc, coordinator_v3, future) speaks this format.",
  "version": "1.0.0",
  "type": "object",
  "required": ["task_id", "intent", "scope", "constraints"],
  "additionalProperties": false,
  "properties": {
    "task_id": {
      "type": "string",
      "pattern": "^task-[0-9]{8}-[0-9]{4}$",
      "description": "Globally unique task ID. Acts as trace root for telemetry spans."
    },
    "parent_task_id": {
      "type": ["string", "null"],
      "description": "Parent task for sub-task fan-out (batch dispatch). null for root tasks."
    },
    "intent": {
      "type": "string",
      "minLength": 10,
      "maxLength": 500,
      "description": "Human-readable description of what this task must accomplish."
    },
    "scope": {
      "type": "object",
      "required": ["machine"],
      "additionalProperties": false,
      "properties": {
        "machine": { "type": "string", "description": "Target machine name from fleet.yaml" },
        "repo":    { "type": "string", "description": "Target repo name from fleet.yaml" },
        "zone":    { "type": "string", "pattern": "^z[0-9]{2}(_[a-z_]+)?$", "description": "x2machines zone ID (e.g. z02_coordination)" },
        "paths":   { "type": "array", "items": { "type": "string" }, "description": "Specific file paths in scope. Empty = entire repo." }
      }
    },
    "constraints": {
      "type": "object",
      "required": ["method", "timeout_s"],
      "additionalProperties": false,
      "properties": {
        "method":     { "enum": ["ssh", "codex", "claude", "local"], "description": "Dispatch method" },
        "timeout_s":  { "type": "integer", "minimum": 30, "maximum": 3600, "description": "Hard timeout in seconds" },
        "budget_usd": { "type": "number", "minimum": 0, "description": "Max spend allowed for this task" },
        "trust_tier": { "type": "integer", "minimum": 0, "maximum": 3, "description": "0=untrusted, 1=engineer, 2=senior, 3=ops" },
        "agent_type": { "enum": ["engineer", "reviewer", "swat", "deployer", "auditor"], "description": "Required agent capability tier" }
      }
    },
    "deadline": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 deadline. Task cancelled if not started before this."
    },
    "agent_affinity": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Preferred agent IDs from agent-registry.yaml. Scheduler uses best-effort affinity."
    },
    "priority": {
      "type": "integer",
      "minimum": 0,
      "maximum": 5,
      "default": 2,
      "description": "0=lowest, 5=highest (SWAT). Feeds ICP optionality_preservation dimension."
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "linear_id":        { "type": "string", "description": "Linear issue identifier (e.g. PAY-1234)" },
        "icp_admission_id": { "type": "string", "description": "ICP admission gate ID for feedback loop" },
        "parent_job_id":    { "type": "string", "description": "develop-cc Job ID of the parent job" },
        "batch_id":         { "type": "string", "description": "Batch ID for fan-out tracking" },
        "zone_role":        { "type": "string", "description": "ICP zone role override (from ZONE_ROLE_MAP)" }
      }
    }
  }
}
