{
  "version": "1.0.0",
  "thresholds": {
    "quarantine_below": 0.95,
    "promote_above": 0.95,
    "window_size": 50
  },
  "report_formats": {
    "jest": {
      "glob": "dist/reports/tests/**/results.json",
      "parser": "jest"
    },
    "pytest": {
      "glob": "dist/reports/tests/**/results.xml",
      "parser": "pytest-junit"
    }
  }
}
