@dataclass
class RescueResult:
    """Drug rescue result with scoring details."""

    drug_name: str
    rescue_score: float  # 0-1, higher = stronger rescue candidate
    antipodal_distance: float  # Cosine distance (more negative = more opposite)
    embedding_space: str
    tier: Optional[str] = None
    metadata: Optional[Dict] = None


@dataclass
class GeneResult:
    """Gene similarity result."""

    gene_name: str
    similarity_score: float  # 0-1, higher = more similar
    tier: Optional[str] = None
    metadata: Optional[Dict] = None


