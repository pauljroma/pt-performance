    def __init__(
        self,
        data_dir: Optional[Path] = None,
        default_embedding_space: str = "ENS"
    ):
        """
        Initialize embedding service.

        Args:
            data_dir: Directory containing parquet files (default: data/embeddings)
            default_embedding_space: Default space for queries (ENS, AEN, RES, etc.)
        """
        self.data_dir = data_dir or (REPO_ROOT / "data" / "embeddings")
        self.default_space = default_embedding_space

        # Lazy-loaded dataframes
        self._gene_df: Optional[pd.DataFrame] = None
        self._drug_df: Optional[pd.DataFrame] = None

        # Cache for frequently accessed data
        self._gene_index: Optional[Dict[str, int]] = None
        self._drug_index: Optional[Dict[str, int]] = None

        # Embedding dimension columns depend on space
        # MODEX genes use MODEX_00, MODEX_01, ... MODEX_31 (32 dimensions)
        # PCA drugs use PCA_0, PCA_1, ... PCA_31 (32 dimensions)
        self._gene_embedding_cols: Optional[List[str]] = None
        self._drug_embedding_cols: Optional[List[str]] = None

        # Drug name resolver for commercial name resolution (Sapphire v3.1)
        self.drug_name_resolver = get_drug_name_resolver()

    def load_gene_embeddings_from_neo4j(self, space_name: str) -> Optional[Dict]:
        """
        Load gene embeddings from Neo4j graph database.

        This method queries Neo4j for gene embeddings stored as node properties.
        It's faster than loading from files and ensures consistency with the graph.

        Args:
            space_name: Embedding space name (e.g., "MODEX_Gene_v1_0", "ENS_v3_1")

        Returns:
            Dict with entity_names, embeddings, dimensions, count, space, format
            OR None if embeddings not found in Neo4j
        """
        try:
            from neo4j import GraphDatabase
        except ImportError:
            print("⚠️ neo4j driver not installed, falling back to file loading")
            return None

        # DEPRECATED: Neo4j property mappings removed in v6.0 (pgvector-only)
        # This method is kept for backward compatibility but will return None
        # Use pgvector_service.py for v6.0 embeddings
        return None

        # Legacy code (disabled):
        # neo4j_property_map = get_neo4j_property_map()
        # if space_name not in neo4j_property_map:
        #     return None
        # property_name = neo4j_property_map[space_name]
        space_config = self.PRODUCTION_EMBEDDINGS.get(space_name)

        if not space_config:
            return None

        # Get Neo4j connection from environment
        neo4j_uri = os.getenv("NEO4J_URI", "bolt://localhost:7687")
        neo4j_user = os.getenv("NEO4J_USER", "neo4j")
        neo4j_password = os.getenv("NEO4J_PASSWORD")

        if not neo4j_password:
            print(f"⚠️ NEO4J_PASSWORD not set, falling back to file loading")
            return None

        driver = None
        try:
            driver = GraphDatabase.driver(neo4j_uri, auth=(neo4j_user, neo4j_password))

            with driver.session() as session:
                # Query for genes with embeddings
                query = f"""
                MATCH (g:Gene)
                WHERE g.{property_name} IS NOT NULL
                RETURN g.symbol as gene_symbol, g.{property_name} as embedding
                ORDER BY g.symbol
                """

                result = session.run(query)
                records = list(result)

                if not records:
                    print(f"⚠️ No genes found with {property_name} in Neo4j")
                    return None

                # Extract gene names and embeddings
                entity_names = []
                embeddings_list = []

                for record in records:
                    entity_names.append(record["gene_symbol"])
                    embeddings_list.append(record["embedding"])

                # Convert to numpy array
                embeddings = np.array(embeddings_list, dtype=np.float32)

                print(f"✓ Loaded {len(entity_names):,} gene embeddings from Neo4j {space_name} ({embeddings.shape[1]}D)")

                return {
                    "entity_names": entity_names,
                    "embeddings": embeddings,
                    "dimensions": embeddings.shape[1],
                    "count": len(entity_names),
                    "space": space_name,
                    "format": "neo4j",
                    "source": "Neo4j graph database"
                }

        except Exception as e:
            print(f"⚠️ Error loading from Neo4j: {e}")
            print(f"   Falling back to file loading for {space_name}")
            return None
        finally:
            if driver:
                driver.close()

    def load_gene_space(self, space_name: str) -> Dict:
        """
        Load gene embeddings from a specific embedding space.

        Sapphire v3.1: Multi-space support for ENS_v3_1, MODEX, Transcript

        **NEW**: Tries Neo4j first for spaces available in graph, falls back to files.

        Args:
            space_name: Name of embedding space (e.g., "ENS_v3_1", "MODEX_Gene_v1_0", "Transcript_v1_Gene")

        Returns:
            Dict with keys:
                - entity_names (List[str]): Gene names
                - embeddings (np.ndarray): Embedding matrix (N x D)
                - dimensions (int): Embedding dimensionality
                - count (int): Number of genes
                - space (str): Space name
                - format (str): File format or 'neo4j'

        Raises:
            ValueError: If space_name not found or not a gene space
            FileNotFoundError: If embedding file not found and not in Neo4j
        """
        # Validate space exists
        if space_name not in self.PRODUCTION_EMBEDDINGS:
            available = [k for k, v in self.PRODUCTION_EMBEDDINGS.items() if v['type'] == 'gene']
            raise ValueError(
                f"Unknown gene space: {space_name}. "
                f"Available gene spaces: {', '.join(available)}"
            )

        space_config = self.PRODUCTION_EMBEDDINGS[space_name]

        # Check if space is marked as unavailable
        if space_config.get('status') == 'unavailable':
            fallback = space_config.get('fallback', 'MODEX_Gene_v1_0')
            raise ValueError(
                f"❌ Embedding space '{space_name}' is unavailable\n"
                f"   Reason: {space_config.get('description', 'Unknown')}\n"
                f"   Fallback: Use '{fallback}' instead\n"
                f"   Note: Git LFS files not downloaded locally"
            )

        # Validate it's a gene space
        if space_config['type'] != 'gene':
            raise ValueError(f"{space_name} is not a gene space (type={space_config['type']})")

        # TRY NEO4J FIRST (faster, ensures graph consistency)
        neo4j_result = self.load_gene_embeddings_from_neo4j(space_name)
        if neo4j_result is not None:
            return neo4j_result

        # FALLBACK TO FILE LOADING
        # Build file path
        file_path = REPO_ROOT / space_config['file']

        if not file_path.exists():
            raise FileNotFoundError(
                f"Gene embeddings not found in Neo4j or files.\n"
                f"  Space: {space_name}\n"
                f"  Expected file: {file_path}\n"
                f"  Hint: Load embeddings to Neo4j or ensure parquet files exist"
            )

        # Load based on format
        file_format = space_config['format']

        if file_format == 'parquet':
            # Load parquet file (e.g., MODEX_Gene_v1_0)
            df = pd.read_parquet(file_path)
            entity_names = df[space_config['entity_col']].tolist()
            embedding_cols = space_config['embedding_cols']
            embeddings = df[embedding_cols].values.astype(np.float32)

        elif file_format == 'npz':
            # Load npz file (e.g., ENS_v3_1, DFP_PhaseII_v1_0)
            data = np.load(file_path)

            # FIX: Determine keys based on space name (backwards compatibility)
            # Different NPZ files use different key names
            if space_name == 'ENS_v3_1':
                entity_key = 'genes'  # ENS_v3_1 uses 'genes' not 'gene_names'
                embedding_key = 'embeddings'
            elif space_name == 'DFP_PhaseII_v1_0':
                entity_key = 'drug_names' if 'drug_names' in data.keys() else 'drugs'
                embedding_key = 'embeddings'
            elif space_name == 'ENS_v3_1_Drug':
                entity_key = 'drugs' if 'drugs' in data.keys() else 'drug_names'
                embedding_key = 'embeddings'
            else:
                # Default keys (try to auto-detect)
                if 'genes' in data.keys():
                    entity_key = 'genes'
                elif 'gene_names' in data.keys():
                    entity_key = 'gene_names'
                elif 'drugs' in data.keys():
                    entity_key = 'drugs'
                elif 'drug_names' in data.keys():
                    entity_key = 'drug_names'
                else:
                    raise ValueError(f"Could not find entity key in NPZ file. Available keys: {list(data.keys())}")
                embedding_key = 'embeddings'

            embeddings = data[embedding_key].astype(np.float32)
            entity_names = data[entity_key].tolist()

            # Handle bytes strings if needed
            if len(entity_names) > 0 and isinstance(entity_names[0], bytes):
                entity_names = [name.decode('utf-8') for name in entity_names]

        elif file_format == 'npy':
            # Load npy file (e.g., Transcript_v1_Gene)
            embeddings = np.load(file_path).astype(np.float32)

            # Load entity names from separate txt file
            entity_file_path = REPO_ROOT / space_config['entity_file']
            if not entity_file_path.exists():
                raise FileNotFoundError(f"Entity names file not found: {entity_file_path}")

            with open(entity_file_path, 'r') as f:
                entity_names = [line.strip() for line in f if line.strip()]

        else:
            raise ValueError(f"Unsupported format: {file_format}")

        # Validate dimensions match
        if embeddings.shape[1] != space_config['dimensions']:
            raise ValueError(
                f"Dimension mismatch for {space_name}: "
                f"expected {space_config['dimensions']}, got {embeddings.shape[1]}"
            )

        # Validate entity count
        if len(entity_names) != embeddings.shape[0]:
            raise ValueError(
                f"Entity count mismatch: {len(entity_names)} names, {embeddings.shape[0]} embeddings"
            )

        print(f"✓ Loaded {len(entity_names):,} gene embeddings from {space_name} ({space_config['dimensions']}D)")

        return {
            "entity_names": entity_names,
            "embeddings": embeddings,
            "dimensions": space_config['dimensions'],
            "count": len(entity_names),
            "space": space_name,
            "format": file_format,
            "description": space_config['description']
        }

    def load_drug_space(self, space_name: str) -> Dict:
        """
        Load drug embeddings from a specific embedding space.

        Sapphire v3.1: Multi-space support including 473K LINCS (Transcript_v1_Drug)

        Args:
            space_name: Name of embedding space (e.g., "PCA_v4_7", "Transcript_v1_Drug", "ENS_v3_1_Drug")

        Returns:
            Dict with keys:
                - entity_names (List[str]): Drug IDs/names
                - embeddings (np.ndarray): Embedding matrix (N x D)
                - dimensions (int): Embedding dimensionality
                - count (int): Number of drugs
                - space (str): Space name
                - format (str): File format

        Raises:
            ValueError: If space_name not found or not a drug space
            FileNotFoundError: If embedding file not found

        Note:
            Transcript_v1_Drug contains 473,647 LINCS L1000 compounds (500K scale).
            Use lazy loading for large spaces to manage memory.
        """
        # Validate space exists
        if space_name not in self.PRODUCTION_EMBEDDINGS:
            available = [k for k, v in self.PRODUCTION_EMBEDDINGS.items() if v['type'] == 'drug']
            raise ValueError(
                f"Unknown drug space: {space_name}. "
                f"Available drug spaces: {', '.join(available)}"
            )

        space_config = self.PRODUCTION_EMBEDDINGS[space_name]

        # Check if space is marked as unavailable
        if space_config.get('status') == 'unavailable':
            fallback = space_config.get('fallback', 'PCA_v4_7')
            raise ValueError(
                f"❌ Embedding space '{space_name}' is unavailable\n"
                f"   Reason: {space_config.get('description', 'Unknown')}\n"
                f"   Fallback: Use '{fallback}' instead\n"
                f"   Note: Git LFS files not downloaded locally"
            )

        # Validate it's a drug space
        if space_config['type'] != 'drug':
            raise ValueError(f"{space_name} is not a drug space (type={space_config['type']})")

        # Build file path
        file_path = REPO_ROOT / space_config['file']

        if not file_path.exists():
            raise FileNotFoundError(f"Drug embedding file not found: {file_path}")

        # Load based on format
        file_format = space_config['format']

        if file_format == 'parquet':
            # Load parquet file (e.g., PCA_v4_7)
            df = pd.read_parquet(file_path)
            entity_names = df[space_config['entity_col']].tolist()
            embedding_cols = space_config['embedding_cols']
            embeddings = df[embedding_cols].values.astype(np.float32)

        elif file_format == 'npz':
            # Load npz file (e.g., DFP_PhaseII_v1_0, ENS_v3_1_Drug)
            data = np.load(file_path)
            embeddings = data[space_config['embedding_key']].astype(np.float32)
            entity_names = data[space_config['entity_key']].tolist()

            # Handle bytes strings if needed
            if len(entity_names) > 0 and isinstance(entity_names[0], bytes):
                entity_names = [name.decode('utf-8') for name in entity_names]

        elif file_format == 'npy':
            # Load npy file (e.g., Transcript_v1_Drug - 473K LINCS, PLATINUM spaces)
            embeddings = np.load(file_path).astype(np.float32)

            # Load entity names from separate txt file
            entity_file_path = REPO_ROOT / space_config['entity_file']
            if not entity_file_path.exists():
                raise FileNotFoundError(f"Entity names file not found: {entity_file_path}")

            with open(entity_file_path, 'r') as f:
                entity_names = [line.strip() for line in f if line.strip()]

            # Special handling for large spaces (Transcript_v1_Drug with 473K drugs)
            if len(entity_names) > 100000:
                print(f"⚠️  Loading large drug space {space_name} with {len(entity_names):,} drugs...")
                print(f"   Memory footprint: ~{embeddings.nbytes / 1024 / 1024:.1f} MB")

        else:
            raise ValueError(f"Unsupported format: {file_format}")

        # Validate dimensions match
        if embeddings.shape[1] != space_config['dimensions']:
            raise ValueError(
                f"Dimension mismatch for {space_name}: "
                f"expected {space_config['dimensions']}, got {embeddings.shape[1]}"
            )

        # Validate entity count
        if len(entity_names) != embeddings.shape[0]:
            raise ValueError(
                f"Entity count mismatch: {len(entity_names)} names, {embeddings.shape[0]} embeddings"
            )

        print(f"✓ Loaded {len(entity_names):,} drug embeddings from {space_name} ({space_config['dimensions']}D)")

        return {
            "entity_names": entity_names,
            "embeddings": embeddings,
            "dimensions": space_config['dimensions'],
            "count": len(entity_names),
            "space": space_name,
            "format": file_format,
            "description": space_config['description']
        }

    def load_drug_embeddings_from_neo4j(self, space_name: str) -> Optional[Dict]:
        """
        Load drug embeddings directly from Neo4j graph database.

        Args:
            space_name: Embedding space name (e.g., "PCA_Drug_v1_0", "PLATINUM_Drug_v1_0")

        Returns:
            Dict with entity_names, embeddings, dimensions, count, space, format
            OR None if embeddings not found in Neo4j
        """
        try:
            from neo4j import GraphDatabase
        except ImportError:
            print("⚠️ neo4j driver not installed, falling back to file loading")
            return None

        # DEPRECATED: Neo4j property mappings removed in v6.0 (pgvector-only)
        # This method is kept for backward compatibility but will return None
        # Use pgvector_service.py for v6.0 embeddings
        return None

        # Legacy code (disabled):
        # neo4j_property_map = get_neo4j_property_map()
        # if space_name not in neo4j_property_map:
        #     return None
        # property_name = neo4j_property_map[space_name]
        space_config = self.PRODUCTION_EMBEDDINGS.get(space_name)

        if not space_config:
            return None

        # Get Neo4j connection from environment
        neo4j_uri = os.getenv("NEO4J_URI", "bolt://localhost:7687")
        neo4j_user = os.getenv("NEO4J_USER", "neo4j")
        neo4j_password = os.getenv("NEO4J_PASSWORD")

        if not neo4j_password:
            print(f"⚠️ NEO4J_PASSWORD not set, falling back to file loading")
            return None

        driver = None
        try:
            driver = GraphDatabase.driver(neo4j_uri, auth=(neo4j_user, neo4j_password))

            with driver.session() as session:
                # Query for drugs with embeddings
                query = f"""
                MATCH (d:Drug)
                WHERE d.{property_name} IS NOT NULL
                RETURN d.qs_code as drug_code, d.{property_name} as embedding
                ORDER BY d.qs_code
                """

                result = session.run(query)
                records = list(result)

                if not records:
                    print(f"⚠️ No drugs found with {property_name} in Neo4j")
                    return None

                # Extract drug codes and embeddings
                entity_names = []
                embeddings_list = []

                for record in records:
                    entity_names.append(record["drug_code"])
                    embeddings_list.append(record["embedding"])

                # Convert to numpy array
                embeddings = np.array(embeddings_list, dtype=np.float32)

                print(f"✓ Loaded {len(entity_names):,} drug embeddings from Neo4j {space_name} ({embeddings.shape[1]}D)")

                return {
                    "entity_names": entity_names,
                    "embeddings": embeddings,
                    "dimensions": embeddings.shape[1],
                    "count": len(entity_names),
                    "space": space_name,
                    "format": "neo4j",
                    "source": "Neo4j graph database"
                }

        except Exception as e:
            print(f"⚠️ Error loading from Neo4j: {e}")
            print(f"   Falling back to file loading for {space_name}")
            return None
        finally:
            if driver:
                driver.close()

    @property
    def gene_df(self) -> pd.DataFrame:
        """Lazy load gene embeddings from Neo4j (or parquet fallback)."""
        if self._gene_df is None:
            # TRY LOADING FROM NEO4J FIRST
            neo4j_data = self.load_gene_embeddings_from_neo4j("MODEX_Gene_v1_0")

            if neo4j_data is not None:
                # Convert Neo4j data to DataFrame format
                entity_names = neo4j_data['entity_names']
                embeddings = neo4j_data['embeddings']

                # Create DataFrame with MODEX column format
                df_data = {'entity_name': entity_names}
                for i in range(32):
                    df_data[f"MODEX_{i:02d}"] = embeddings[:, i]

                self._gene_df = pd.DataFrame(df_data)

                # Create lookup index
                self._gene_index = {
                    row['entity_name']: idx
                    for idx, row in self._gene_df.iterrows()
                }

                self._gene_embedding_cols = [f"MODEX_{i:02d}" for i in range(32)]

                print(f"✓ Loaded {len(self._gene_df):,} gene embeddings from Neo4j (MODEX 32D)")

            else:
                # FALLBACK: Load from parquet file
                gene_path = self.data_dir / "MODEX_gene_v1.0_PRODUCTION.parquet"
                if not gene_path.exists():
                    raise FileNotFoundError(
                        f"Gene embeddings not found in Neo4j or files.\n"
                        f"  Expected file: {gene_path}\n"
                        f"  Hint: Load embeddings to Neo4j or ensure parquet files exist"
                    )

                self._gene_df = pd.read_parquet(gene_path)

                # Create lookup index
                self._gene_index = {
                    row['entity_name']: idx
                    for idx, row in self._gene_df.iterrows()
                }

                # MODEX uses 32-dimensional embeddings with format MODEX_00 to MODEX_31
                self._gene_embedding_cols = [f"MODEX_{i:02d}" for i in range(32)]

                print(f"✓ Loaded {len(self._gene_df):,} gene embeddings from parquet (MODEX 32D)")

        return self._gene_df

    @property
    def drug_df(self) -> pd.DataFrame:
        """Lazy load drug embeddings from Neo4j (or parquet fallback)."""
        if self._drug_df is None:
            # TRY LOADING FROM NEO4J FIRST (using correct space name from registry)
            neo4j_data = self.load_drug_embeddings_from_neo4j("PCA_v4_7")

            if neo4j_data is not None:
                # Convert Neo4j data to DataFrame format
                entity_names = neo4j_data['entity_names']
                embeddings = neo4j_data['embeddings']

                # Create DataFrame with PCA column format (PCA_0 to PCA_31)
                df_data = {'entity_name': entity_names}
                for i in range(32):
                    df_data[f"PCA_{i}"] = embeddings[:, i]

                self._drug_df = pd.DataFrame(df_data)

                # Create lookup index
                self._drug_index = {
                    row['entity_name']: idx
                    for idx, row in self._drug_df.iterrows()
                }

                # PCA uses 32-dimensional embeddings with format PCA_0 to PCA_31
                self._drug_embedding_cols = [f"PCA_{i}" for i in range(32)]

                print(f"✓ Loaded {len(self._drug_df):,} drug embeddings from Neo4j (PCA 32D)")
            else:
                # FALLBACK: Load from parquet file
                drug_path = self.data_dir / "PCA_v4.7_FULL_40_drug_v1.0.parquet"
                if not drug_path.exists():
                    raise FileNotFoundError(f"Drug embeddings not found: {drug_path}")

                self._drug_df = pd.read_parquet(drug_path)

                # Create lookup index (PCA drugs don't have entity_name, use index)
                if 'entity_name' in self._drug_df.columns:
                    self._drug_index = {
                        row['entity_name']: idx
                        for idx, row in self._drug_df.iterrows()
                    }
                else:
                    # PCA file uses index directly
                    self._drug_index = {str(idx): idx for idx in self._drug_df.index}

                # PCA uses 32-dimensional embeddings with format PCA_0 to PCA_31
                self._drug_embedding_cols = [f"PCA_{i}" for i in range(32)]

                print(f"✓ Loaded {len(self._drug_df):,} drug embeddings from parquet (PCA 32D)")

        return self._drug_df

    def get_gene_embedding(self, gene_name: str) -> Optional[np.ndarray]:
        """
        Get embedding vector for a gene.

        Args:
            gene_name: Gene symbol (e.g., "TSC2")

        Returns:
            32-dimensional MODEX embedding vector or None if not found
        """
        # Trigger lazy loading
        _ = self.gene_df

        if gene_name not in self._gene_index:
            return None

        idx = self._gene_index[gene_name]
        row = self.gene_df.loc[idx]

        # Extract embedding columns (MODEX 32D)
        embedding = row[self._gene_embedding_cols].values.astype(np.float32)

        return embedding

    def get_drug_embedding(self, drug_name: str) -> Optional[np.ndarray]:
        """
        Get embedding vector for a drug.

        Args:
            drug_name: Drug name or index

        Returns:
            32-dimensional PCA embedding vector or None if not found
        """
        # Trigger lazy loading
        _ = self.drug_df

        if drug_name not in self._drug_index:
            return None

        idx = self._drug_index[drug_name]
        row = self.drug_df.loc[idx]

        # Extract embedding columns (PCA 32D)
        embedding = row[self._drug_embedding_cols].values.astype(np.float32)

        return embedding

    def compute_rescue_scores(
        self,
        gene: str,
        top_k: int = 10,
        embedding_space: Optional[str] = None,
        min_score: float = 0.5
    ) -> List[RescueResult]:
        """
        Compute drug rescue scores for a gene.

        Drug rescue is defined as antipodal similarity: drugs with embeddings
        most opposite to the gene's embedding in the chosen space.

        Args:
            gene: Gene symbol (e.g., "TSC2")
            top_k: Number of top results to return
            embedding_space: Embedding space to use (default: ENS)
            min_score: Minimum rescue score threshold (0-1)

        Returns:
            List of RescueResult objects, sorted by rescue score (descending)
        """
        # Get gene embedding
        gene_emb = self.get_gene_embedding(gene)
        if gene_emb is None:
            raise ValueError(f"Gene not found in embeddings: {gene}")

        # Normalize gene embedding
        gene_emb_norm = gene_emb / (np.linalg.norm(gene_emb) + 1e-8)

        # Get all drug embeddings (PCA 32D)
        drug_embeddings = self.drug_df[self._drug_embedding_cols].values.astype(np.float32)

        # Normalize drug embeddings
        drug_norms = np.linalg.norm(drug_embeddings, axis=1, keepdims=True) + 1e-8
        drug_embeddings_norm = drug_embeddings / drug_norms

        # Compute cosine similarity (dot product of normalized vectors)
        cosine_similarities = drug_embeddings_norm @ gene_emb_norm

        # Antipodal score: more negative = more opposite = better rescue
        # Convert to 0-1 scale where 1 = perfect antipodal (-1 cosine similarity)
        rescue_scores = (1.0 - cosine_similarities) / 2.0

        # Filter by minimum score
        valid_indices = np.where(rescue_scores >= min_score)[0]

        # Sort by rescue score (descending)
        sorted_indices = valid_indices[np.argsort(-rescue_scores[valid_indices])]

        # Take top K
        top_indices = sorted_indices[:top_k]

        # Build results
        results = []
        for idx in top_indices:
            drug_row = self.drug_df.iloc[idx]

            # PCA drugs may not have entity_name, use index
            drug_id = drug_row.get('entity_name', f"DRUG_{idx}")

            # Resolve commercial name (Sapphire v3.1 feature)
            name_info = self.drug_name_resolver.resolve(drug_id)
            commercial_name = name_info['commercial_name']

            result = RescueResult(
                drug_name=drug_id,  # Keep QS ID for traceability
                rescue_score=float(rescue_scores[idx]),
                antipodal_distance=float(cosine_similarities[idx]),
                embedding_space="MODEX-PCA",  # Cross-space rescue
                tier=drug_row.get('best_hit_tier', drug_row.get('data_tier')),
                metadata={
                    'index': int(idx),
                    'norm': float(drug_norms[idx][0]),
                    'entity_type': drug_row.get('entity_type', 'drug'),
                    'commercial_name': commercial_name,  # v3.1: Commercial name
                    'chembl_id': name_info.get('chembl_id', ''),
                    'name_source': name_info.get('source', 'none')
                }
            )
            results.append(result)

        return results

    def find_similar_genes(
        self,
        gene: str,
        top_k: int = 10,
        min_similarity: float = 0.5
    ) -> List[GeneResult]:
        """
        Find genes most similar to the query gene.

        Args:
            gene: Query gene symbol
            top_k: Number of results to return
            min_similarity: Minimum similarity threshold (0-1)

        Returns:
            List of GeneResult objects, sorted by similarity (descending)
        """
        # Get query gene embedding
        gene_emb = self.get_gene_embedding(gene)
        if gene_emb is None:
            raise ValueError(f"Gene not found in embeddings: {gene}")

        # Normalize query embedding
        gene_emb_norm = gene_emb / (np.linalg.norm(gene_emb) + 1e-8)

        # Get all gene embeddings
        gene_embeddings = self.gene_df[self._gene_embedding_cols].values.astype(np.float32)

        # Normalize gene embeddings
        gene_norms = np.linalg.norm(gene_embeddings, axis=1, keepdims=True) + 1e-8
        gene_embeddings_norm = gene_embeddings / gene_norms

        # Compute cosine similarities
        similarities = gene_embeddings_norm @ gene_emb_norm

        # Filter by minimum similarity (exclude self)
        query_idx = self._gene_index[gene]
        valid_mask = (similarities >= min_similarity) & (np.arange(len(similarities)) != query_idx)
        valid_indices = np.where(valid_mask)[0]

        # Sort by similarity (descending)
        sorted_indices = valid_indices[np.argsort(-similarities[valid_indices])]

        # Take top K
        top_indices = sorted_indices[:top_k]

        # Build results
        results = []
        for idx in top_indices:
            gene_row = self.gene_df.iloc[idx]

            result = GeneResult(
                gene_name=gene_row['entity_name'],
                similarity_score=float(similarities[idx]),
                tier=gene_row.get('best_hit_tier'),
                metadata={
                    'index': int(idx),
                    'norm': float(gene_norms[idx][0]),
                    'entity_type': gene_row.get('entity_type'),
                    'hit_rate': gene_row.get('hit_rate')
                }
            )
            results.append(result)

        return results

    def get_gene_classification(self, gene: str) -> Optional[Dict]:
        """
        Get gene classification and metadata.

        Args:
            gene: Gene symbol

        Returns:
            Dictionary with gene metadata (tier, classification, etc.)
        """
        # Trigger lazy loading
        _ = self.gene_df

        if gene not in self._gene_index:
            return None

        idx = self._gene_index[gene]
        row = self.gene_df.loc[idx]

        return {
            'gene': gene,
            'tier': row.get('best_hit_tier'),
            'index': int(idx),
            'entity_name': row['entity_name'],
            'entity_type': row.get('entity_type'),
            'total_signatures': row.get('total_signatures'),
            'hit_signatures': row.get('hit_signatures'),
            'hit_rate': row.get('hit_rate'),
            'T1_count': row.get('T1_count'),
            'T2_count': row.get('T2_count'),
            'T3_count': row.get('T3_count'),
            'mean_hit_strength': row.get('mean_hit_strength'),
            'max_hit_strength': row.get('max_hit_strength')
        }

    def get_stats(self) -> Dict:
        """Get service statistics."""
        return {
            'genes_loaded': len(self.gene_df) if self._gene_df is not None else 0,
            'drugs_loaded': len(self.drug_df) if self._drug_df is not None else 0,
            'gene_embedding_dimensions': len(self._gene_embedding_cols) if self._gene_embedding_cols else 32,
            'drug_embedding_dimensions': len(self._drug_embedding_cols) if self._drug_embedding_cols else 32,
            'default_space': self.default_space,
            'available_spaces': list(self.EMBEDDING_SPACES.keys())
        }


# Singleton instance
_embedding_service: Optional[EmbeddingService] = None


def get_embedding_service() -> EmbeddingService:
    """Get or create singleton embedding service instance."""
    global _embedding_service
    if _embedding_service is None:
        _embedding_service = EmbeddingService()
    return _embedding_service


if __name__ == "__main__":
    # Test the service
    import argparse

    parser = argparse.ArgumentParser(description="Test embedding service")
    parser.add_argument("--gene", default="TSC2", help="Gene to query")
    parser.add_argument("--top-k", type=int, default=10, help="Number of results")

    args = parser.parse_args()

    print(f"\n=== Embedding Service Test ===\n")

    service = get_embedding_service()

    print(f"Service stats: {service.get_stats()}\n")

    print(f"Testing drug rescue for {args.gene}...\n")

    try:
        results = service.compute_rescue_scores(args.gene, top_k=args.top_k)

        print(f"Top {len(results)} rescue candidates for {args.gene}:\n")

        for i, result in enumerate(results, 1):
            print(f"{i}. {result.drug_name}")
            print(f"   Rescue Score: {result.rescue_score:.3f}")
            print(f"   Antipodal Distance: {result.antipodal_distance:.3f}")
            print(f"   Tier: {result.tier}")
            print()

        # Test gene similarity
        print(f"\nTop 5 genes similar to {args.gene}:\n")

        gene_results = service.find_similar_genes(args.gene, top_k=5)

        for i, result in enumerate(gene_results, 1):
            print(f"{i}. {result.gene_name}")
            print(f"   Similarity: {result.similarity_score:.3f}")
            print(f"   Tier: {result.tier}")
            print()

    except ValueError as e:
        print(f"Error: {e}")
