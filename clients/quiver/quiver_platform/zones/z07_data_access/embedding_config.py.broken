def get_neo4j_property_map() -> Dict[str, str]:
    """
    Auto-generate Neo4j property map from PRODUCTION_EMBEDDINGS registry.

    Returns mapping of space name → Neo4j property name for all spaces
    that have Neo4j support (neo4j_property is not None).

    Benefits:
    - NO MORE HARDCODING: Mappings derived from single source of truth
    - Automatic: Adding new space with neo4j_property automatically includes it
    - Type-safe: Guaranteed to match PRODUCTION_EMBEDDINGS registry

    Returns:
        Dict mapping space names to Neo4j property names
        Example: {"MODEX_Gene_v1_0": "embedding_modex", ...}

    Example:
        >>> prop_map = get_neo4j_property_map()
        >>> prop_map["PCA_v4_7"]
        'embedding_pca'
    """
    return {
        space_name: config.neo4j_property
        for space_name, config in PRODUCTION_EMBEDDINGS.items()
        if config.neo4j_property is not None  # Only spaces with Neo4j support
    }


def get_spaces_by_type(space_type: Literal['gene', 'drug']) -> Dict[str, EmbeddingSpaceConfig]:
    """
    Get all embedding spaces of a specific type.

    Args:
        space_type: 'gene' or 'drug'

    Returns:
        Dict of space configurations filtered by type

    Example:
        >>> gene_spaces = get_spaces_by_type('gene')
        >>> len(gene_spaces)
        3
    """
    return {
        space_name: config
        for space_name, config in PRODUCTION_EMBEDDINGS.items()
        if config.type == space_type
    }


def get_neo4j_spaces() -> Dict[str, EmbeddingSpaceConfig]:
    """
    Get all embedding spaces that have Neo4j support.

    Returns:
        Dict of space configurations that have neo4j_property set

    Example:
        >>> neo4j_spaces = get_neo4j_spaces()
        >>> all(s.neo4j_property is not None for s in neo4j_spaces.values())
        True
    """
    return {
        space_name: config
        for space_name, config in PRODUCTION_EMBEDDINGS.items()
        if config.neo4j_property is not None
    }


def get_available_spaces() -> Dict[str, EmbeddingSpaceConfig]:
    """
    Get all embedding spaces that are available (active status).

    Returns:
        Dict of space configurations that are currently available

    Example:
        >>> available = get_available_spaces()
        >>> len(available)
        6
    """
    return {
        space_name: config
        for space_name, config in PRODUCTION_EMBEDDINGS.items()
        if config.status == 'active'
    }


def resolve_fallback_space(space_name: str) -> str:
    """
    Resolve fallback space for an unavailable embedding space.

    Args:
        space_name: Name of unavailable space

    Returns:
        Name of fallback space, or original space_name if no fallback

    Example:
        >>> fallback = resolve_fallback_space('PLATINUM_Similarity_v1_0')
        >>> fallback
        'PCA_v4_7'
    """
    if space_name not in PRODUCTION_EMBEDDINGS:
        return space_name

    config = PRODUCTION_EMBEDDINGS[space_name]

    # If explicitly marked unavailable, use fallback
    if config.status == 'unavailable' and config.fallback_space:
        return config.fallback_space

    # Otherwise return original
    return space_name


# Export summary for debugging
def print_config_summary():
    """Print configuration summary for verification."""
    print("=" * 80)
    print("EMBEDDING CONFIGURATION SUMMARY")
    print("=" * 80)
    print(f"\nTotal Spaces: {len(PRODUCTION_EMBEDDINGS)}")

    gene_spaces = get_spaces_by_type('gene')
    drug_spaces = get_spaces_by_type('drug')
    neo4j_spaces = get_neo4j_spaces()
    file_only_spaces = {
        k: v for k, v in PRODUCTION_EMBEDDINGS.items()
        if v.neo4j_property is None
    }

    print(f"Gene Spaces: {len(gene_spaces)}")
    print(f"Drug Spaces: {len(drug_spaces)}")
    print(f"Neo4j-Supported: {len(neo4j_spaces)}")
    print(f"File-Only: {len(file_only_spaces)}")

    print("\n" + "=" * 80)
    print("NEO4J PROPERTY MAPPINGS")
    print("=" * 80)
    for space_name, neo4j_prop in sorted(get_neo4j_property_map().items()):
        config = PRODUCTION_EMBEDDINGS[space_name]
        print(f"{space_name:25s} → {neo4j_prop:20s} ({config.dimensions}D, {config.type})")

    print("\n" + "=" * 80)
    print("FILE-ONLY SPACES (No Neo4j)")
    print("=" * 80)
    for space_name in sorted(file_only_spaces.keys()):
        config = file_only_spaces[space_name]
        print(f"{space_name:25s} ({config.dimensions}D, {config.entity_count:,} {config.type}s)")

    print("=" * 80)


if __name__ == "__main__":
    # Run summary when executed directly
    print_config_summary()
