"""
Centralized Embedding Configuration - SINGLE SOURCE OF TRUTH

This module provides centralized configuration for all embedding spaces used in Sapphire v3.
All Neo4j property mappings, space definitions, and metadata are managed here.

Purpose:
- Eliminate hardcoded Neo4j property mappings scattered throughout the codebase
- Provide type-safe configuration via dataclasses
- Auto-generate mappings from a single registry
- Reduce maintenance burden (adding new space: 1 place vs 5+ places)

Architecture:
- EmbeddingSpaceConfig: Type-safe dataclass for space configuration
- PRODUCTION_EMBEDDINGS: Master registry of all 11 embedding spaces
- get_neo4j_property_map(): Auto-generate Neo4j mappings from registry

Version: 1.1
Date: 2025-11-29
Changes:
- Added MODEX_Gene_16D_v2_0 (16D gene embeddings for antipodal rescue)
- Added DFP_PhaseII_16D_v1_0 (16D drug embeddings for antipodal rescue)
- Total spaces: 9 → 11 (4 gene, 7 drug)
"""

from typing import Dict, Literal, Optional
from dataclasses import dataclass
from pathlib import Path


@dataclass
class EmbeddingSpaceConfig:
    """
    Configuration for a single embedding space.

    Attributes:
        name: Unique identifier for the space (e.g., "MODEX_Gene_v1_0")
        type: Entity type - 'gene' or 'drug'
        dimensions: Embedding dimensionality (16, 32, or 64)
        node_label: Neo4j node label for querying (Gene or Drug)
        neo4j_property: Neo4j property name storing embeddings (e.g., "embedding_modex")
                        None if space is file-only (no Neo4j support)
        entity_type: Entity type for metadata queries
        file_path: Relative path to fallback file (parquet, npy, or npz)
        description: Human-readable description of the embedding space
        format: File format - 'parquet', 'npy', or 'npz'
        entity_count: Expected number of entities in this space
        status: Space status - 'active', 'degraded', 'unavailable'
                (default: 'active')
        degradation_reason: If status='degraded', brief explanation
        fallback_space: Recommended fallback space name if unavailable
    """
    name: str
    type: Literal['gene', 'drug']
    dimensions: int
    node_label: str
    neo4j_property: Optional[str]  # None for file-only spaces
    entity_type: str
    file_path: str
    description: str
    format: Literal['parquet', 'npy', 'npz']
    entity_count: int
    status: Literal['active', 'degraded', 'unavailable'] = 'active'
    degradation_reason: Optional[str] = None
    fallback_space: Optional[str] = None


