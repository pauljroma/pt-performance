"""
Vector Similarity Tool - Cross-Entity Embedding Comparison

ARCHITECTURE DECISION LOG:
v1.0 (current): Pure agentic with atomic tools
  - This tool provides Claude with entity similarity capabilities
  - Supports gene-gene, drug-drug, and cross-entity (gene-drug) comparisons
  - Handles case-insensitive entity matching with fuzzy matching for typos
  - Returns cosine similarity (0-1 scale), distance, and embedding space metadata

Pattern: Wraps EmbeddingService.compute_cosine_similarity()
Reference: /Users/expo/Code/expo/clients/quiver/quiver_platform/zones/z07_data_access/embedding_service.py
"""

from typing import Dict, Any, Optional, Tuple
from pathlib import Path
import sys
import numpy as np

# Import harmonization utilities (Stream 1: Foundation)
try:
    from tool_utils import validate_tool_input, format_validation_response, harmonize_drug_id, validate_input
    HARMONIZATION_AVAILABLE = True
    VALIDATION_AVAILABLE = True
except ImportError:
    HARMONIZATION_AVAILABLE = False

# Add path for embedding service
project_root = Path(__file__).parent.parent.parent.parent.parent.parent
sys.path.insert(0, str(project_root))

from clients.quiver.quiver_platform.zones.z07_data_access.embedding_service import get_embedding_service
from clients.quiver.quiver_platform.zones.z07_data_access.drug_name_resolver import get_drug_name_resolver


# Claude Tool Definition (Anthropic format)
TOOL_DEFINITION = {
    "name": "vector_similarity",
    "description": """Compare cosine similarity between any two entities using their embeddings.

Supports pairwise similarity comparisons across:
- Gene-gene: Compare genetic signatures (MODEX 32D)
- Drug-drug: Compare chemical/functional profiles (PCA 32D)
- Gene-drug: Cross-space similarity (MODEX × PCA)

Uses fast normalized dot product computation (<2ms latency).

Examples:
- "What's the similarity between TSC2 and TP53?" → Gene-gene comparison
- "How similar are aspirin and ibuprofen?" → Drug-drug comparison
- "Compare TSC2 to QS0318588_10uM" → Cross-space comparison
- "similarity between kncq2 and brca1" → Case-insensitive, handles fuzzy matching

Output metrics:
- similarity_score: 0-1 scale (1 = identical, 0 = orthogonal, <0 possible for antipodal)
- cosine_distance: Raw cosine similarity (-1 to 1)
- entity_types: Confirmed types of both entities
- embedding_spaces: Spaces used for each entity

Data:
- 18,368 genes (MODEX 32D)
- 14,246 drugs (PCA 32D)
- Direct parquet access
""",
    "input_schema": {
        "type": "object",
        "properties": {
            "entity1": {
                "type": "string",
                "description": "First entity name (gene symbol or drug name, case-insensitive). Examples: TSC2, TP53, KCNQ2, aspirin, QS0318588_10uM"
            },
            "entity2": {
                "type": "string",
                "description": "Second entity name (gene symbol or drug name, case-insensitive). Examples: BRCA1, SCN1A, ibuprofen, paracetamol"
            }
        },
        "required": ["entity1", "entity2"]
    }
}


def _normalize_embedding(embedding: np.ndarray) -> np.ndarray:
    """
    Normalize embedding vector to unit length.

    Args:
        embedding: Raw embedding vector

    Returns:
        Normalized embedding vector
    """
    norm = np.linalg.norm(embedding) + 1e-8
    return embedding / norm


def _compute_cosine_similarity(vec1: np.ndarray, vec2: np.ndarray) -> float:
    """
    Compute cosine similarity between two vectors.

    Args:
        vec1: First normalized vector
        vec2: Second normalized vector

    Returns:
        Cosine similarity (-1 to 1)
    """
    return float(np.dot(vec1, vec2))


def _find_entity_in_dataframe(
    entity_name: str,
    entity_df,
    entity_type: str
) -> Optional[Tuple[str, Any]]:
    """
    Find entity in dataframe with fuzzy matching support.

    Tries in order:
    1. Exact match
    2. Case-insensitive match
    3. Fuzzy match (Levenshtein distance, 80% threshold)

    Args:
        entity_name: Entity to search for
        entity_df: DataFrame with entity_name column
        entity_type: "gene" or "drug" for context

    Returns:
        Tuple of (normalized_name, row) or None if not found
    """
    if entity_df is None or entity_df.empty:
        return None

    entity_names = entity_df['entity_name'].values if 'entity_name' in entity_df.columns else []

    if not len(entity_names):
        return None

    # Try exact match first (fastest)
    if entity_name in entity_names:
        row = entity_df[entity_df['entity_name'] == entity_name].iloc[0]
        return (entity_name, row)

    # Try case-insensitive match
    entity_upper = entity_name.upper()
    matches = [e for e in entity_names if e.upper() == entity_upper]

    if matches:
        found_name = matches[0]
        row = entity_df[entity_df['entity_name'] == found_name].iloc[0]
        return (found_name, row)

    # Fuzzy match using Levenshtein distance for typos
    from difflib import get_close_matches

    close_matches = get_close_matches(
        entity_upper,
        [e.upper() for e in entity_names],
        n=1,
        cutoff=0.8
    )

    if close_matches:
        matched_upper = close_matches[0]
        found_name = next(e for e in entity_names if e.upper() == matched_upper)
        row = entity_df[entity_df['entity_name'] == found_name].iloc[0]
        return (found_name, row)

    # No match found
    return None


async def execute(tool_input: Dict[str, Any]) -> Dict[str, Any]:

    # Stream 1.2: Input validation
    if VALIDATION_AVAILABLE:
        validation_errors = validate_tool_input(tool_input, TOOL_DEFINITION["input_schema"], "vector_similarity")
        if validation_errors:
            return format_validation_response("vector_similarity", validation_errors)
    """
    Execute vector_similarity tool - compare two entities by embedding similarity.

    This is a thin wrapper around EmbeddingService methods.
    Handles case-insensitive entity matching and formats results for Claude.

    Args:
        tool_input: Dict with keys:
            - entity1 (str): First entity name (case-insensitive)
            - entity2 (str): Second entity name (case-insensitive)

    Returns:
        Dict with keys:
            - success (bool): Whether operation succeeded
            - entity1 (str): Normalized entity1 name
            - entity2 (str): Normalized entity2 name
            - similarity_score (float): 0-1 scale similarity
            - cosine_distance (float): Raw cosine similarity (-1 to 1)
            - entity1_type (str): Type of entity1 (gene or drug)
            - entity2_type (str): Type of entity2 (gene or drug)
            - embedding_space (str): Space(s) used for comparison
            - interpretation (str): Human-readable interpretation
            - error (str, optional): Error message if failed

    Example:
        >>> await execute({"entity1": "TSC2", "entity2": "TP53"})
        {
            "success": True,
            "entity1": "TSC2",
            "entity2": "TP53",
            "similarity_score": 0.742,
            "cosine_distance": 0.742,
            "entity1_type": "gene",
            "entity2_type": "gene",
            "embedding_space": "MODEX × MODEX",
            "interpretation": "High similarity - genes may share functional roles",
            "data_source": "Direct parquet (MODEX 32D × PCA 32D)"
        }
    """
    try:
        # Get parameters
        entity1_input = tool_input.get("entity1", "").strip()
        entity2_input = tool_input.get("entity2", "").strip()

        # Validate parameters
        if not entity1_input or not isinstance(entity1_input, str):
            return {
                "success": False,
                "error": "entity1 parameter must be a non-empty string",
                "hint": "Examples: TSC2, TP53, aspirin, paracetamol"
            }

        if not entity2_input or not isinstance(entity2_input, str):
            return {
                "success": False,
                "error": "entity2 parameter must be a non-empty string",
                "hint": "Examples: BRCA1, SCN1A, ibuprofen, QS0318588_10uM"
            }

        # Get embedding service
        embedding_service = get_embedding_service()
        if embedding_service is None:
            return {
                "success": False,
                "error": "Embedding service not available",
                "hint": "Check that embedding data files are present"
            }

        # Try to find entities in gene and drug dataframes
        entity1_as_gene = None
        entity1_as_drug = None
        entity2_as_gene = None
        entity2_as_drug = None

        # Search for entity1
        try:
            entity1_as_gene = _find_entity_in_dataframe(
                entity1_input,
                embedding_service.gene_df,
                "gene"
            )
        except Exception:
            pass

        try:
            entity1_as_drug = _find_entity_in_dataframe(
                entity1_input,
                embedding_service.drug_df,
                "drug"
            )
        except Exception:
            pass

        # Search for entity2
        try:
            entity2_as_gene = _find_entity_in_dataframe(
                entity2_input,
                embedding_service.gene_df,
                "gene"
            )
        except Exception:
            pass

        try:
            entity2_as_drug = _find_entity_in_dataframe(
                entity2_input,
                embedding_service.drug_df,
                "drug"
            )
        except Exception:
            pass

        # Determine entity types and select best match
        entity1_name = None
        entity1_type = None
        entity1_embedding = None

        if entity1_as_gene:
            entity1_name = entity1_as_gene[0]
            entity1_type = "gene"
            entity1_embedding = embedding_service.get_gene_embedding(entity1_name)
        elif entity1_as_drug:
            entity1_name = entity1_as_drug[0]
            entity1_type = "drug"
            entity1_embedding = embedding_service.get_drug_embedding(entity1_name)

        entity2_name = None
        entity2_type = None
        entity2_embedding = None

        if entity2_as_gene:
            entity2_name = entity2_as_gene[0]
            entity2_type = "gene"
            entity2_embedding = embedding_service.get_gene_embedding(entity2_name)
        elif entity2_as_drug:
            entity2_name = entity2_as_drug[0]
            entity2_type = "drug"
            entity2_embedding = embedding_service.get_drug_embedding(entity2_name)

        # Check if both entities were found
        if entity1_embedding is None:
            return {
                "success": False,
                "error": f"Entity not found in embeddings: {entity1_input}",
                "entity": entity1_input,
                "hint": "Entity not found. Try checking spelling or using standard gene/drug symbols.",
                "available_genes": f"{len(embedding_service.gene_df):,} genes in MODEX database",
                "available_drugs": f"{len(embedding_service.drug_df):,} drugs in PCA database",
                "examples_genes": ["TSC2", "SCN1A", "KCNQ2", "BRCA1", "TP53", "STXBP1"],
                "examples_drugs": ["aspirin", "ibuprofen", "paracetamol", "QS0318588_10uM"]
            }

        if entity2_embedding is None:
            return {
                "success": False,
                "error": f"Entity not found in embeddings: {entity2_input}",
                "entity": entity2_input,
                "hint": "Entity not found. Try checking spelling or using standard gene/drug symbols.",
                "available_genes": f"{len(embedding_service.gene_df):,} genes in MODEX database",
                "available_drugs": f"{len(embedding_service.drug_df):,} drugs in PCA database",
                "examples_genes": ["TSC2", "SCN1A", "KCNQ2", "BRCA1", "TP53", "STXBP1"],
                "examples_drugs": ["aspirin", "ibuprofen", "paracetamol", "QS0318588_10uM"]
            }

        # Normalize embeddings
        entity1_norm = _normalize_embedding(entity1_embedding)
        entity2_norm = _normalize_embedding(entity2_embedding)

        # Compute cosine similarity
        cosine_distance = _compute_cosine_similarity(entity1_norm, entity2_norm)

        # Convert to 0-1 similarity score (0 = orthogonal, 1 = identical, <0 = antipodal)
        # For interpretability, we'll use (1 + cosine_distance) / 2 to get 0-1 range
        # But also return raw cosine distance
        similarity_score = (1.0 + cosine_distance) / 2.0

        # Determine embedding space used
        embedding_space = f"{entity1_type.upper()} × {entity2_type.upper()}"
        if entity1_type == "gene":
            embedding_space = embedding_space.replace("GENE", "MODEX")
        if entity2_type == "gene":
            embedding_space = embedding_space.replace("GENE", "MODEX")
        if entity1_type == "drug":
            embedding_space = embedding_space.replace("DRUG", "PCA")
        if entity2_type == "drug":
            embedding_space = embedding_space.replace("DRUG", "PCA")

        # Generate interpretation
        if cosine_distance >= 0.8:
            interpretation = "Very high similarity - entities may be functionally equivalent or closely related"
        elif cosine_distance >= 0.6:
            interpretation = "High similarity - entities likely share functional roles or biological pathways"
        elif cosine_distance >= 0.4:
            interpretation = "Moderate similarity - entities have some functional or structural relationship"
        elif cosine_distance >= 0.0:
            interpretation = "Low similarity - entities are relatively independent"
        elif cosine_distance >= -0.4:
            interpretation = "Very low similarity - entities appear functionally distinct"
        else:
            interpretation = "Antipodal similarity - entities may have opposite biological effects"

        # Sapphire v3.1: Resolve commercial names for drugs
        drug_name_resolver = get_drug_name_resolver()

        # Build base result
        result = {
            "success": True,
            "entity1_input": entity1_input,
            "entity1_type": entity1_type,
            "entity2_input": entity2_input,
            "entity2_type": entity2_type,
            "similarity_score": round(similarity_score, 4),
            "cosine_distance": round(cosine_distance, 4),
            "embedding_space": embedding_space,
            "interpretation": interpretation,
            "data_source": "Direct parquet (MODEX 32D × PCA 32D)",
            "latency": "<2ms",
            "metadata": {
                "raw_cosine": round(cosine_distance, 6),
                "entity1_norm": float(np.linalg.norm(entity1_embedding)),
                "entity2_norm": float(np.linalg.norm(entity2_embedding))
            }
        }

        # Add entity1 info (with commercial name if drug)
        if entity1_type == "drug":
            name_info = drug_name_resolver.resolve(entity1_name)
            result["entity1_drug_id"] = entity1_name
            result["entity1_commercial_name"] = name_info['commercial_name']
            result["entity1_chembl_id"] = name_info.get('chembl_id', '')
            result["entity1_name_source"] = name_info.get('source', 'none')
        else:
            result["entity1"] = entity1_name

        # Add entity2 info (with commercial name if drug)
        if entity2_type == "drug":
            name_info = drug_name_resolver.resolve(entity2_name)
            result["entity2_drug_id"] = entity2_name
            result["entity2_commercial_name"] = name_info['commercial_name']
            result["entity2_chembl_id"] = name_info.get('chembl_id', '')
            result["entity2_name_source"] = name_info.get('source', 'none')
        else:
            result["entity2"] = entity2_name

        return result

    except ValueError as e:
        # Entity not found in embeddings
        error_msg = str(e)
        return {
            "success": False,
            "error": error_msg,
            "hint": "Entity not found in embedding database. Check spelling or try symbol variations.",
            "available_genes": "18,368 genes in MODEX database",
            "available_drugs": "14,246 drugs in PCA database",
            "examples_genes": ["TSC2", "SCN1A", "KCNQ2", "BRCA1", "TP53", "STXBP1"],
            "examples_drugs": ["aspirin", "ibuprofen", "paracetamol"]
        }

    except Exception as e:
        # Unexpected error
        return {
            "success": False,
            "error": f"Unexpected error: {str(e)}",
            "error_type": type(e).__name__,
            "entity1": tool_input.get("entity1", "unknown"),
            "entity2": tool_input.get("entity2", "unknown")
        }


# Export tool for registration
__all__ = ["TOOL_DEFINITION", "execute"]
