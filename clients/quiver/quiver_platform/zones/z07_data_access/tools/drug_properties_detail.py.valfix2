#!/usr/bin/env python3
"""
Drug Properties Detail Tool - Query ChEMBL PostgreSQL for comprehensive drug data

Provides deep dive into drug properties from the 226GB PostgreSQL warehouse:
- ADME properties (absorption, distribution, metabolism, excretion)
- Clinical trial status
- Molecular properties
- Toxicity data
- Formulations and routes of administration

Author: claude-code-agent
Date: 2025-11-28
Version: 1.0
"""

from typing import Dict, Any
import sys
from pathlib import Path

# Import harmonization utilities (Stream 1: Foundation)
try:
    from tool_utils import validate_tool_input, format_validation_response, harmonize_drug_id, validate_input
    HARMONIZATION_AVAILABLE = True
    VALIDATION_AVAILABLE = True
except ImportError:
    HARMONIZATION_AVAILABLE = False

# Add parent directory to path for imports
sys.path.insert(0, str(Path(__file__).parent.parent))

from postgres_connection import query_postgres


TOOL_DEFINITION = {
    "name": "drug_properties_detail",
    "description": """Query comprehensive drug properties from ChEMBL PostgreSQL database (226GB warehouse).

    This tool provides deep scientific details about drugs beyond what's in embeddings:
    - Molecular properties (MW, LogP, PSA, HBD/HBA)
    - ADME properties (absorption, distribution, metabolism, excretion)
    - Clinical trial phases and status
    - Toxicity profiles
    - Formulations and administration routes
    - Chemical structure details

    Use this when you need detailed drug characterization, not just similarity.

    Example queries:
    - "Show me detailed properties for Sirolimus"
    - "What's the clinical trial status of Everolimus?"
    - "Give me ADME properties for mTOR inhibitors"
    """,
    "input_schema": {
        "type": "object",
        "properties": {
            "drug_name": {
                "type": "string",
                "description": "Drug identifier in any format: Drug name, ChEMBL ID (CHEMBL1234), RxNorm ID (1234567), or LINCS ID (BRD-K...)."
            },
            "property_types": {
                "type": "array",
                "items": {
                    "type": "string",
                    "enum": ["molecular", "adme", "clinical", "toxicity", "all"]
                },
                "default": ["all"],
                "description": "Which property types to retrieve"
            }
        },
        "required": ["drug_name"]
    }
}


async def execute(tool_input: Dict[str, Any]) -> Dict[str, Any]:
    """Execute drug properties lookup from PostgreSQL."""
    # Stream 1.2: Input validation
    if VALIDATION_AVAILABLE:
        validation_errors = validate_tool_input(tool_input, TOOL_DEFINITION["input_schema"], "drug_properties_detail")
        if validation_errors:
            return format_validation_response("drug_properties_detail", validation_errors)

    try:
        drug_name = tool_input["drug_name"]

        # STREAM 1: Identifier harmonization
        harmonization_note = None
        drug_normalized = drug_name

        if HARMONIZATION_AVAILABLE:
            # Try harmonization (handles ChEMBL IDs, RxNorm IDs, LINCS IDs)
            harmonized = harmonize_drug_id(drug_name)
            if harmonized["success"]:
                # Use ChEMBL ID if available (most tools use ChEMBL)
                if harmonized.get("chembl_id"):
                    drug_chembl_id = harmonized["chembl_id"]
                    harmonization_note = f"Harmonized {harmonized['id_type_detected']} → ChEMBL"
                # Or use the drug name
                if harmonized.get("drug_name"):
                    drug_normalized = harmonized["drug_name"]
        property_types = tool_input.get("property_types", ["all"])

        # Normalize property types
        if "all" in property_types:
            property_types = ["molecular", "adme", "clinical", "toxicity"]

        result = {
            "success": True,
            "drug_name": drug_name,
            "data_source": "ChEMBL PostgreSQL (rescue database)",
            "properties": {}
        }

        # Query molecular properties
        if "molecular" in property_types:
            result["properties"]["molecular"] = await get_molecular_properties(drug_name)

        # Query ADME properties
        if "adme" in property_types:
            result["properties"]["adme"] = await get_adme_properties(drug_name)

        # Query clinical trial data
        if "clinical" in property_types:
            result["properties"]["clinical"] = await get_clinical_data(drug_name)

        # Query toxicity data
        if "toxicity" in property_types:
            result["properties"]["toxicity"] = await get_toxicity_data(drug_name)

        # Check if we found any data
        has_data = any(result["properties"].values())
        if not has_data:
            result["success"] = False
            result["error"] = f"No ChEMBL data found for '{drug_name}'"
            result["hint"] = "Drug may not be in ChEMBL database, or try alternative name"

        return result

    except Exception as e:
        import traceback
        return {
            "success": False,
            "error": f"Drug properties query failed: {str(e)}",
            "traceback": traceback.format_exc(),
            "hint": "Database may not be accessible. Check PostgreSQL connection."
        }


async def get_molecular_properties(drug_name: str) -> Dict[str, Any]:
    """Query molecular properties from ChEMBL."""
    try:
        query = """
        SELECT
            md.pref_name,
            md.chembl_id,
            cs.canonical_smiles,
            cs.standard_inchi,
            cp.mw_freebase as molecular_weight,
            cp.alogp,
            cp.hba as h_bond_acceptors,
            cp.hbd as h_bond_donors,
            cp.psa as polar_surface_area,
            cp.rtb as rotatable_bonds,
            cp.aromatic_rings,
            cp.heavy_atoms,
            md.max_phase as development_phase
        FROM molecule_dictionary md
        LEFT JOIN compound_structures cs ON md.molregno = cs.molregno
        LEFT JOIN compound_properties cp ON md.molregno = cp.molregno
        WHERE LOWER(md.pref_name) = LOWER($1)
           OR LOWER(md.pref_name) LIKE LOWER($1 || '%')
        LIMIT 1
        """

        result = await query_postgres(query, [drug_name], database="rescue")

        if result:
            row = result[0]
            return {
                "found": True,
                "chembl_id": row.get("chembl_id"),
                "preferred_name": row.get("pref_name"),
                "molecular_weight": row.get("molecular_weight"),
                "alogp": row.get("alogp"),
                "h_bond_acceptors": row.get("h_bond_acceptors"),
                "h_bond_donors": row.get("h_bond_donors"),
                "polar_surface_area": row.get("polar_surface_area"),
                "rotatable_bonds": row.get("rotatable_bonds"),
                "aromatic_rings": row.get("aromatic_rings"),
                "heavy_atoms": row.get("heavy_atoms"),
                "development_phase": row.get("development_phase"),
                "smiles": row.get("canonical_smiles"),
                "inchi": row.get("standard_inchi")[:100] + "..." if row.get("standard_inchi") else None
            }
        else:
            return {"found": False}

    except Exception as e:
        return {"found": False, "error": str(e)}


async def get_adme_properties(drug_name: str) -> Dict[str, Any]:
    """Query ADME properties from ChEMBL."""
    try:
        # This is a placeholder - actual ADME data depends on ChEMBL schema
        query = """
        SELECT md.pref_name, cp.alogp, cp.hba, cp.hbd
        FROM molecule_dictionary md
        LEFT JOIN compound_properties cp ON md.molregno = cp.molregno
        WHERE LOWER(md.pref_name) = LOWER($1)
        LIMIT 1
        """

        result = await query_postgres(query, [drug_name], database="rescue")

        if result:
            row = result[0]
            return {
                "found": True,
                "lipophilicity_alogp": row.get("alogp"),
                "absorption_estimate": "High" if row.get("alogp", 0) > 0 and row.get("alogp", 0) < 5 else "Moderate",
                "hba": row.get("hba"),
                "hbd": row.get("hbd"),
                "note": "ADME predictions based on molecular properties"
            }
        else:
            return {"found": False}

    except Exception as e:
        return {"found": False, "error": str(e)}


async def get_clinical_data(drug_name: str) -> Dict[str, Any]:
    """Query clinical trial information from ChEMBL."""
    try:
        query = """
        SELECT
            md.pref_name,
            md.max_phase,
            md.therapeutic_flag,
            md.oral,
            md.parenteral,
            md.topical,
            md.black_box_warning,
            md.first_approval,
            md.withdrawn_flag,
            md.withdrawn_year
        FROM molecule_dictionary md
        WHERE LOWER(md.pref_name) = LOWER($1)
        LIMIT 1
        """

        result = await query_postgres(query, [drug_name], database="rescue")

        if result:
            row = result[0]
            max_phase = row.get("max_phase")

            phase_desc = {
                0: "Preclinical",
                1: "Phase I (Safety)",
                2: "Phase II (Efficacy)",
                3: "Phase III (Large-scale)",
                4: "Approved"
            }.get(max_phase, "Unknown")

            return {
                "found": True,
                "max_phase": max_phase,
                "phase_description": phase_desc,
                "therapeutic_flag": bool(row.get("therapeutic_flag")),
                "administration_routes": {
                    "oral": bool(row.get("oral")),
                    "parenteral": bool(row.get("parenteral")),
                    "topical": bool(row.get("topical"))
                },
                "safety": {
                    "black_box_warning": bool(row.get("black_box_warning")),
                    "withdrawn": bool(row.get("withdrawn_flag")),
                    "withdrawn_year": row.get("withdrawn_year")
                },
                "first_approval": row.get("first_approval")
            }
        else:
            return {"found": False}

    except Exception as e:
        return {"found": False, "error": str(e)}


async def get_toxicity_data(drug_name: str) -> Dict[str, Any]:
    """Query toxicity information from ChEMBL."""
    try:
        # Placeholder - actual toxicity queries depend on schema
        query = """
        SELECT md.pref_name, md.black_box_warning, md.withdrawn_flag
        FROM molecule_dictionary md
        WHERE LOWER(md.pref_name) = LOWER($1)
        LIMIT 1
        """

        result = await query_postgres(query, [drug_name], database="rescue")

        if result:
            row = result[0]
            return {
                "found": True,
                "black_box_warning": bool(row.get("black_box_warning")),
                "withdrawn": bool(row.get("withdrawn_flag")),
                "note": "Additional toxicity data available in drug_adverse_effects table"
            }
        else:
            return {"found": False}

    except Exception as e:
        return {"found": False, "error": str(e)}


# Export for tool registration
__all__ = ["TOOL_DEFINITION", "execute"]
