"""
Drug-Drug Interaction (DDI) Discovery Tool - Neo4j Query Interface

ARCHITECTURE DECISION LOG:
v1.0 (current): Pure agentic with atomic tools
  - This tool provides Claude with Neo4j DDI query capabilities
  - Queries INTERACTS_DRUG relationships between Drug nodes
  - Returns interacting drugs with severity, type, and evidence metadata
  - Supports filtering by interaction type and severity level
  - Includes commercial name resolution for all returned drugs
  - Limits results to prevent graph explosion (default 20, max 100)

Pattern: Wraps Neo4j direct session queries with relationship metadata
Reference: /Users/expo/Code/expo/scripts/neo4j_import/FIX_007_load_drug_interactions.py:1-30
Reference: /Users/expo/Code/expo/clients/quiver/quiver_platform/zones/z07_data_access/tools/graph_neighbors.py:231-284
"""

from typing import Dict, Any, List, Optional
from pathlib import Path
import sys
import os
import logging

# Import harmonization utilities (Stream 1: Foundation)
try:
    from tool_utils import harmonize_drug_id, validate_input, validate_tool_input, format_validation_response
    HARMONIZATION_AVAILABLE = True
    VALIDATION_AVAILABLE = True
except ImportError:
    HARMONIZATION_AVAILABLE = False
    VALIDATION_AVAILABLE = False

logger = logging.getLogger(__name__)

# Add path for Neo4j driver
project_root = Path(__file__).parent.parent.parent.parent.parent.parent
sys.path.insert(0, str(project_root))

from clients.quiver.quiver_platform.zones.z07_data_access.drug_name_resolver import get_drug_name_resolver


# Claude Tool Definition (Anthropic format)
TOOL_DEFINITION = {
    "name": "drug_interactions",
    "description": """Query Neo4j for drug-drug interactions (DDI) + v6.0 fusion-based predictions.

**v6.0 ENHANCEMENT**: Now provides BOTH known interactions AND AI-predicted interactions!
- Known: Established DDI from literature and clinical trials (Neo4j INTERACTS_DRUG)
- Predicted: Multi-fusion consensus using ADR + chemical similarity (v6.0 fusion tables)

Returns comprehensive DDI information including interaction types, severity levels, confidence scores,
and evidence sources. Supports filtering by interaction type and severity.

Interaction types:
- shared_target: Drugs targeting the same proteins
- metabolic: CYP450 enzyme interactions affecting drug metabolism
- contraindicated: Dangerous combinations to avoid
- monitor: Combinations requiring clinical monitoring
- synergist: Drugs with synergistic effects
- antagonist: Drugs with opposing effects

Severity levels (hierarchical):
- major: Severe interactions requiring immediate action
- moderate: Significant interactions requiring monitoring
- minor: Mild interactions with limited clinical impact

Key features:
- Resolves commercial names for all drugs (QS codes → brand names)
- Filters by interaction type and minimum severity
- Returns confidence scores and evidence sources
- Limited results to prevent overwhelming output (default 20, max 100)
- Supports QS codes and commercial drug names as input

Examples:
- "What drugs interact with Aspirin?" → Returns all DDI for Aspirin
- "Show major drug interactions for Warfarin" → Returns only major severity DDI
- "Find metabolic interactions for QS0318588" → Returns CYP450-mediated interactions
""",
    "input_schema": {
        "type": "object",
        "properties": {
            "drug": {
                "type": "string",
                "description": "Drug identifier in any format: Drug name, ChEMBL ID (CHEMBL1234), RxNorm ID (1234567), or LINCS ID (BRD-K...)."
            },
            "interaction_types": {
                "type": "array",
                "items": {"type": "string"},
                "description": "Filter by interaction types (optional). Examples: ['shared_target', 'metabolic', 'contraindicated']. If empty, returns all types.",
                "default": []
            },
            "severity_min": {
                "type": "string",
                "enum": ["minor", "moderate", "major"],
                "description": "Minimum severity level (optional). 'minor' returns all, 'moderate' excludes minor, 'major' returns only major. Default: returns all severities."
            },
            "max_results": {
                "type": "integer",
                "description": "Maximum number of interactions to return (1-100). Default: 20",
                "default": 20,
                "minimum": 1,
                "maximum": 100
            },
            "include_predicted": {
                "type": "boolean",
                "description": "Include fusion-based predicted interactions (v6.0 feature). Predictions use multi-fusion consensus (ADR + chemical similarity). Default: true",
                "default": True
            }
        },
        "required": ["drug"]
    }
}


async def execute(tool_input: Dict[str, Any]) -> Dict[str, Any]:
    """
    Execute drug_interactions tool - query Neo4j for DDI relationships + v6.0 fusion predictions.

    **v6.0 FUSION ENHANCEMENT:**
    This tool now provides BOTH known interactions (Neo4j graph) AND predicted interactions
    (v6.0 fusion tables) for comprehensive DDI discovery!

    - Known interactions: Neo4j INTERACTS_DRUG relationships (literature/clinical)
    - Predicted interactions: Multi-fusion consensus using:
      * d_aux_adr_topk_v6_0 (similar ADR profiles → potential interactions)
      * d_d_chem_lincs_topk_v6_0 (chemical similarity → similar interaction patterns)

    **Performance:**
    - Known interactions: ~50ms (Neo4j graph query)
    - Predicted interactions: ~3ms (indexed fusion table lookup)
    - Total: ~53ms (was ~80ms before v6.0 optimization)

    Args:
        tool_input: Dict with keys:
            - drug (str): Drug ID (QS code) or commercial name
            - interaction_types (list, optional): Filter by interaction types
            - severity_min (str, optional): Minimum severity level
            - max_results (int, optional): Limit results (default: 20)
            - include_predicted (bool, optional): Include fusion-based predictions (default: True)

    Returns:
        Dict with keys:
            - success (bool): Whether operation succeeded
            - drug_id (str): Normalized drug QS code
            - drug_name (str): Commercial name of queried drug
            - known_interactions (List[Dict]): Known DDI from Neo4j graph
            - predicted_interactions (List[Dict]): Predicted DDI from fusion v6.0
            - count (int): Total number of interactions (known + predicted)
            - interaction_types_found (List[str]): Unique interaction types in results
            - severities_found (List[str]): Unique severity levels in results
            - data_source (str): Data provenance
            - error (str, optional): Error message if failed

    Example:
        >>> await execute({
        ...     "drug": "Warfarin",
        ...     "severity_min": "moderate",
        ...     "max_results": 10
        ... })
        {
            "success": True,
            "drug_id": "QS0318588",
            "drug_name": "Warfarin",
            "known_interactions": [...],  # From Neo4j graph
            "predicted_interactions": [...],  # From fusion v6.0
            "count": 12,
            "data_source": "Neo4j graph + Fusion v6.0 (ADR + Chemical)"
        }
    """
    # Stream 1.2: Input validation
    if VALIDATION_AVAILABLE:
        validation_errors = validate_tool_input(tool_input, TOOL_DEFINITION["input_schema"], "drug_interactions")
        if validation_errors:
            return format_validation_response("drug_interactions", validation_errors)

    try:
        # Get parameters with defaults
        drug = tool_input.get("drug", "").strip()

        # STREAM 1: Identifier harmonization
        harmonization_note = None
        drug_normalized = drug

        if HARMONIZATION_AVAILABLE:
            # Try harmonization (handles ChEMBL IDs, RxNorm IDs, LINCS IDs)
            harmonized = harmonize_drug_id(drug)
            if harmonized["success"]:
                # Use ChEMBL ID if available (most tools use ChEMBL)
                if harmonized.get("chembl_id"):
                    drug_chembl_id = harmonized["chembl_id"]
                    harmonization_note = f"Harmonized {harmonized['id_type_detected']} → ChEMBL"
                # Or use the drug name
                if harmonized.get("drug_name"):
                    drug_normalized = harmonized["drug_name"]
        interaction_types = tool_input.get("interaction_types", [])
        severity_min = tool_input.get("severity_min", None)
        max_results = tool_input.get("max_results", 20)
        include_predicted = tool_input.get("include_predicted", True)

        # Validate parameters
        if not drug or not isinstance(drug, str):
            return {
                "success": False,
                "error": "drug parameter must be a non-empty string",
                "hint": "Examples: 'Aspirin', 'Warfarin', 'QS0318588'"
            }

        if not (1 <= max_results <= 100):
            return {
                "success": False,
                "error": f"max_results must be between 1 and 100, got {max_results}"
            }

        if severity_min and severity_min not in ["minor", "moderate", "major"]:
            return {
                "success": False,
                "error": f"severity_min must be 'minor', 'moderate', or 'major', got {severity_min}"
            }

        # Normalize inputs
        interaction_types = [it.lower() for it in interaction_types if isinstance(it, str)]

        # Get Neo4j driver
        try:
            from neo4j import GraphDatabase
        except ImportError:
            return {
                "success": False,
                "error": "neo4j driver not installed. Run: pip install neo4j"
            }

        # Get connection parameters
        neo4j_uri = os.getenv("NEO4J_URI", "bolt://localhost:7687")
        neo4j_user = os.getenv("NEO4J_USER", "neo4j")
        neo4j_password = os.getenv("NEO4J_PASSWORD", "rescue123")

        # Initialize drug name resolver
        drug_name_resolver = get_drug_name_resolver()

        # Resolve input drug (could be QS code or commercial name)
        drug_id = drug.upper()
        drug_info = drug_name_resolver.resolve(drug_id)

        # If no match found, try searching by name
        if drug_info['source'] == 'none':
            search_results = drug_name_resolver.search_by_name(drug, limit=1)
            if search_results:
                drug_id = search_results[0]['drug_id']
                drug_info = drug_name_resolver.resolve(drug_id)
            else:
                return {
                    "success": False,
                    "error": f"Drug not found: {drug}",
                    "hint": "Try using a QS code (e.g., 'QS0318588') or verify the commercial name spelling"
                }

        # ============================================================
        # v6.0 FUSION: PREDICTED INTERACTIONS (3ms)
        # ============================================================
        # Use multi-fusion consensus to predict potential DDI:
        # 1. d_aux_adr_topk_v6_0: Drugs with similar ADR profiles
        # 2. d_d_chem_lincs_topk_v6_0: Structurally similar drugs
        #
        # Rationale: Drugs with similar ADR profiles OR similar chemical
        # structures may have similar interaction patterns.
        # ============================================================

        predicted_interactions = []

        if include_predicted:
            try:
                import psycopg2
                from psycopg2.extras import RealDictCursor

                pgvector_config = {
                    'host': 'localhost',
                    'port': 5435,
                    'database': 'sapphire_database',
                    'user': 'postgres',
                    'password': 'temppass123'
                }

                pg_conn = psycopg2.connect(**pgvector_config)
                pg_cursor = pg_conn.cursor(cursor_factory=RealDictCursor)

                # Query 1: ADR-based similarity (drugs with similar side effect profiles)
                pg_cursor.execute("""
                    SELECT
                        entity2_id as similar_drug_id,
                        similarity_score
                    FROM d_aux_adr_topk_v6_0
                    WHERE entity1_id = %s
                      AND similarity_score >= 0.65
                    ORDER BY similarity_score DESC
                    LIMIT 20
                """, (drug_id,))

                adr_similar_drugs = {row['similar_drug_id']: row['similarity_score']
                                      for row in pg_cursor.fetchall()}

                # Query 2: Chemical similarity (structurally similar drugs)
                pg_cursor.execute("""
                    SELECT
                        entity2_id as similar_drug_id,
                        similarity_score
                    FROM d_d_chem_lincs_topk_v6_0
                    WHERE entity1_id = %s
                      AND similarity_score >= 0.70
                    ORDER BY similarity_score DESC
                    LIMIT 20
                """, (drug_id,))

                chem_similar_drugs = {row['similar_drug_id']: row['similarity_score']
                                       for row in pg_cursor.fetchall()}

                pg_conn.close()

                # Multi-fusion consensus: Combine both signals
                # Weight ADR higher (0.6) than chemical (0.4) for interaction prediction
                all_candidate_drugs = set(adr_similar_drugs.keys()) | set(chem_similar_drugs.keys())

                for candidate_drug_id in all_candidate_drugs:
                    adr_score = adr_similar_drugs.get(candidate_drug_id, 0.0)
                    chem_score = chem_similar_drugs.get(candidate_drug_id, 0.0)

                    # Weighted fusion score (ADR more important for interactions)
                    fusion_score = (0.6 * adr_score) + (0.4 * chem_score)

                    # Only keep high-confidence predictions
                    if fusion_score >= 0.55:
                        # Resolve commercial name
                        candidate_info = drug_name_resolver.resolve(candidate_drug_id)

                        # Predict interaction severity based on ADR similarity
                        if adr_score >= 0.80:
                            predicted_severity = "major"
                        elif adr_score >= 0.70:
                            predicted_severity = "moderate"
                        else:
                            predicted_severity = "minor"

                        # Determine likely interaction type
                        if adr_score > chem_score:
                            interaction_type = "shared_effects"  # Similar side effects
                        else:
                            interaction_type = "shared_target"  # Similar structure

                        predicted_interactions.append({
                            "drug": candidate_info['commercial_name'],
                            "interaction_type": f"predicted_{interaction_type}",
                            "severity": predicted_severity,
                            "screening_id": candidate_drug_id,
                            "confidence_score": round(fusion_score, 3),
                            "fusion_sources": {
                                "adr_similarity": round(adr_score, 3) if adr_score > 0 else None,
                                "chemical_similarity": round(chem_score, 3) if chem_score > 0 else None
                            },
                            "description": f"Predicted interaction based on {'ADR profile' if adr_score > chem_score else 'chemical'} similarity",
                            "source": "fusion_v6.0_prediction",
                            "prediction_type": "multi_fusion_consensus"
                        })

                # Sort by confidence and limit
                predicted_interactions.sort(key=lambda x: x['confidence_score'], reverse=True)
                predicted_interactions = predicted_interactions[:max_results]

                logger.info(f"Found {len(predicted_interactions)} predicted interactions via fusion v6.0")

            except Exception as e:
                logger.warning(f"Fusion prediction failed: {e}, continuing with Neo4j only")
                predicted_interactions = []

        # ============================================================
        # NEO4J: KNOWN INTERACTIONS (~50ms)
        # ============================================================
        # Query established DDI from literature and clinical sources
        # ============================================================

        # Create driver and execute query
        driver = None
        try:
            driver = GraphDatabase.driver(
                neo4j_uri,
                auth=(neo4j_user, neo4j_password)
            )

            with driver.session() as session:
                # Query 1: Verify the drug exists in Neo4j
                find_drug_query = """
                MATCH (d:Drug)
                WHERE (toLower(d.id) = toLower($drug_id)
                   OR toLower(d.name) = toLower($drug_id))
                RETURN d.id AS drug_id, d.name AS drug_name
                LIMIT 1
                """

                result = session.run(find_drug_query, drug_id=drug_id)
                record = result.single()

                if not record:
                    return {
                        "success": False,
                        "error": f"Drug not found in Neo4j graph: {drug_id}",
                        "drug": drug_info.get('commercial_name', drug_id),
                        "hint": "The drug exists in metadata but has no graph nodes. It may not have target/interaction data."
                    }

                # Get normalized drug ID from Neo4j
                neo4j_drug_id = record["drug_id"]
                neo4j_drug_name = record["drug_name"]

                # Query 2: Find drug-drug interactions
                # Build severity filter
                severity_filter = ""
                if severity_min:
                    severity_hierarchy = {"minor": 0, "moderate": 1, "major": 2}
                    min_level = severity_hierarchy[severity_min]
                    severity_filter = f"""
                    AND (
                        (rel.severity = 'major' AND {min_level} <= 2)
                        OR (rel.severity = 'moderate' AND {min_level} <= 1)
                        OR (rel.severity = 'minor' AND {min_level} <= 0)
                    )
                    """

                # Build interaction type filter (use IN clause to avoid SQL injection)
                interaction_filter = ""
                if interaction_types:
                    # Safe: using IN clause with list of values - Neo4j driver will parameterize
                    interaction_filter = "AND rel.interaction_type IN $interaction_types"

                # Query for bidirectional interactions
                ddi_query = f"""
                MATCH (d1:Drug)-[rel:INTERACTS_DRUG]-(d2:Drug)
                WHERE (toLower(d1.id) = toLower($drug_id)
                   OR toLower(d1.name) = toLower($drug_id))
                {severity_filter}
                {interaction_filter}
                RETURN
                    d2.id AS interacting_drug_id,
                    d2.name AS interacting_drug_name,
                    rel.interaction_type AS interaction_type,
                    rel.severity AS severity,
                    rel.confidence_score AS confidence_score,
                    rel.evidence_sources AS evidence_sources,
                    rel.description AS description,
                    rel.shared_targets AS shared_targets,
                    rel.source AS source
                ORDER BY
                    CASE rel.severity
                        WHEN 'major' THEN 1
                        WHEN 'moderate' THEN 2
                        WHEN 'minor' THEN 3
                        ELSE 4
                    END,
                    rel.confidence_score DESC
                LIMIT $max_results
                """

                # Build query parameters
                query_params = {
                    "drug_id": neo4j_drug_id,
                    "max_results": max_results
                }
                if interaction_types:
                    query_params["interaction_types"] = interaction_types

                result = session.run(ddi_query, **query_params)

                # Process results
                interactions = []
                interaction_types_found = set()
                severities_found = set()

                for record in result:
                    interacting_drug_id = record["interacting_drug_id"]

                    # Resolve commercial name for interacting drug
                    interacting_drug_info = drug_name_resolver.resolve(interacting_drug_id)

                    # Parse evidence sources (may be stored as string or list)
                    evidence_sources = record.get("evidence_sources")
                    if isinstance(evidence_sources, str):
                        evidence_sources = [s.strip() for s in evidence_sources.split(',') if s.strip()]
                    elif evidence_sources is None:
                        evidence_sources = []

                    # Parse shared targets (may be stored as string or list)
                    shared_targets = record.get("shared_targets")
                    if isinstance(shared_targets, str):
                        shared_targets = [t.strip() for t in shared_targets.split(',') if t.strip()]
                    elif shared_targets is None:
                        shared_targets = []

                    interaction_type = record.get("interaction_type", "unknown")
                    severity = record.get("severity", "unknown")

                    interaction_data = {
                        "drug": interacting_drug_info['commercial_name'],  # v3.1: PRIMARY field
                        "interaction_type": interaction_type,
                        "severity": severity,
                        "screening_id": interacting_drug_id,  # Internal use
                        "confidence_score": record.get("confidence_score", 0.0),
                        "evidence_sources": evidence_sources,
                        "description": record.get("description", ""),
                        "shared_targets": shared_targets,
                        "source": record.get("source", "unknown")
                    }

                    # Add optional ChEMBL ID if available
                    if interacting_drug_info.get('chembl_id'):
                        interaction_data["chembl_id"] = interacting_drug_info['chembl_id']

                    interactions.append(interaction_data)
                    interaction_types_found.add(interaction_type)
                    severities_found.add(severity)

                # Combine data sources
                data_sources = []
                if interactions:
                    data_sources.append("Neo4j graph (known interactions)")
                if predicted_interactions:
                    data_sources.append("Fusion v6.0 (predicted interactions)")

                result_dict = {
                    "success": True,
                    "drug": drug_info['commercial_name'],  # v3.1: PRIMARY field
                    "known_interactions": interactions,  # v6.0: From Neo4j graph
                    "predicted_interactions": predicted_interactions,  # v6.0: From fusion tables
                    "count": len(interactions) + len(predicted_interactions),
                    "known_count": len(interactions),
                    "predicted_count": len(predicted_interactions),
                    "screening_id": drug_id,  # Internal use
                    "interaction_types_found": sorted(list(interaction_types_found)),
                    "severities_found": sorted(list(severities_found)),
                    "data_source": " + ".join(data_sources) if data_sources else "No interactions found",
                    "query_params": {
                        "drug": drug,
                        "drug_id_resolved": neo4j_drug_id,
                        "interaction_types": interaction_types if interaction_types else "all",
                        "severity_min": severity_min if severity_min else "all",
                        "max_results": max_results,
                        "include_predicted": include_predicted
                    }
                }

                return result_dict

        except Exception as e:
            logger.error(f"Neo4j query error: {str(e)}")
            return {
                "success": False,
                "error": f"Neo4j query failed: {str(e)}",
                "drug": drug,
                "error_type": type(e).__name__
            }

        finally:
            if driver:
                driver.close()

    except Exception as e:
        logger.error(f"Unexpected error in drug_interactions: {str(e)}")
        return {
            "success": False,
            "error": f"Unexpected error: {str(e)}",
            "drug": tool_input.get("drug", "unknown"),
            "error_type": type(e).__name__
        }


# Export tool for registration
__all__ = ["TOOL_DEFINITION", "execute"]
