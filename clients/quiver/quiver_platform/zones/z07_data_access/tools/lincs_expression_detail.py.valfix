#!/usr/bin/env python3
"""
LINCS Expression Detail Tool - Query L1000 gene expression data from PostgreSQL

Provides deep dive into gene expression profiles from the 226GB PostgreSQL warehouse:
- Gene expression across 1000+ cell lines
- Differential expression analysis
- Perturbation signatures
- Drug-induced expression changes
- Cell-type specific expression patterns

Author: claude-code-agent
Date: 2025-11-28
Version: 1.0
"""

from typing import Dict, Any, List
import sys
from pathlib import Path

# Import harmonization utilities (Stream 1: Foundation)
try:
    from tool_utils import validate_tool_input, format_validation_response, harmonize_gene_id, harmonize_drug_id, validate_input, normalize_gene_symbol
    HARMONIZATION_AVAILABLE = True
except ImportError:
    HARMONIZATION_AVAILABLE = False

# Add parent directory to path for imports
sys.path.insert(0, str(Path(__file__).parent.parent))

from postgres_connection import query_postgres


TOOL_DEFINITION = {
    "name": "lincs_expression_detail",
    "description": """Query detailed gene expression data from LINCS L1000 PostgreSQL database.

    This tool provides comprehensive gene expression profiles from LINCS L1000:
    - Expression across 1000+ cell lines and tissues
    - Drug perturbation signatures (how drugs affect gene expression)
    - Differential expression (up/down regulation)
    - Cell-type specific patterns
    - Time-course expression data

    Use this for detailed expression analysis beyond similarity search.

    Example queries:
    - "Show me TSC2 expression across all LINCS cell lines"
    - "How does Sirolimus affect gene expression?"
    - "What's the differential expression for TP53 in cancer vs normal?"
    - "Show me perturbation signatures for mTOR inhibitors"
    """,
    "input_schema": {
        "type": "object",
        "properties": {
            "query_type": {
                "type": "string",
                "enum": ["gene_expression", "drug_perturbation", "cell_line_specific"],
                "description": (
                    "Type of expression query:\n"
                    "- gene_expression: Expression profile for a gene across cell lines\n"
                    "- drug_perturbation: How a drug affects gene expression\n"
                    "- cell_line_specific: Expression in specific cell line(s)"
                )
            },
            "gene_symbol": {
                "type": "string",
                "description": "Gene symbol (for gene_expression and cell_line_specific queries)"
            },
            "drug_name": {
                "type": "string",
                "description": "Drug name (for drug_perturbation queries)"
            },
            "cell_line": {
                "type": "string",
                "description": "Cell line name (optional filter for any query)"
            },
            "limit": {
                "type": "integer",
                "default": 20,
                "description": "Maximum number of results to return"
            }
        },
        "required": ["query_type"]
    }
}


async def execute(tool_input: Dict[str, Any]) -> Dict[str, Any]:
    """Execute LINCS expression query from PostgreSQL."""
    # Stream 1.2: Input validation
    if VALIDATION_AVAILABLE:
        validation_errors = validate_tool_input(tool_input, TOOL_DEFINITION["input_schema"], "lincs_expression_detail")
        if validation_errors:
            return format_validation_response("lincs_expression_detail", validation_errors)

    try:
        query_type = tool_input["query_type"]
        gene_symbol = tool_input.get("gene_symbol")
        drug_name = tool_input.get("drug_name")
        cell_line = tool_input.get("cell_line")
        limit = tool_input.get("limit", 20)

        # Route to appropriate query function
        if query_type == "gene_expression":
            if not gene_symbol:
                return {
                    "success": False,
                    "error": "gene_symbol required for gene_expression query"
                }
            result = await query_gene_expression(gene_symbol, cell_line, limit)

        elif query_type == "drug_perturbation":
            if not drug_name:
                return {
                    "success": False,
                    "error": "drug_name required for drug_perturbation query"
                }
            result = await query_drug_perturbation(drug_name, cell_line, limit)

        elif query_type == "cell_line_specific":
            if not gene_symbol or not cell_line:
                return {
                    "success": False,
                    "error": "Both gene_symbol and cell_line required for cell_line_specific query"
                }
            result = await query_cell_line_specific(gene_symbol, cell_line)

        else:
            return {
                "success": False,
                "error": f"Unknown query_type: {query_type}"
            }

        result["success"] = True
        result["data_source"] = "LINCS L1000 PostgreSQL (rescue database)"
        return result

    except Exception as e:
        import traceback
        return {
            "success": False,
            "error": f"LINCS expression query failed: {str(e)}",
            "traceback": traceback.format_exc(),
            "hint": "Database may not be accessible or LINCS tables not loaded"
        }


async def query_gene_expression(
    gene_symbol: str,
    cell_line_filter: str = None,
    limit: int = 20
) -> Dict[str, Any]:
    """Query gene expression across cell lines."""
    try:
        # Query gene expression data
        # Note: Actual schema depends on how LINCS was loaded
        where_clause = "WHERE gi.pr_gene_symbol = $1"
        params = [gene_symbol]

        if cell_line_filter:
            where_clause += " AND si.cell_id LIKE $2"
            params.append(f"%{cell_line_filter}%")

        query = f"""
        SELECT
            gi.pr_gene_symbol as gene_symbol,
            gi.pr_gene_id,
            si.cell_id,
            si.pert_iname as perturbation,
            si.pert_type,
            COUNT(*) as signature_count
        FROM
            lincs_gene_info gi
        CROSS JOIN
            lincs_sig_info si
        {where_clause}
        GROUP BY gi.pr_gene_symbol, gi.pr_gene_id, si.cell_id, si.pert_iname, si.pert_type
        ORDER BY signature_count DESC
        LIMIT ${ len(params) + 1}
        """

        params.append(limit)
        results = await query_postgres(query, params, database="rescue")

        if results:
            return {
                "gene": gene_symbol,
                "cell_lines_found": len(set(r["cell_id"] for r in results)),
                "total_signatures": sum(r["signature_count"] for r in results),
                "expression_profiles": [
                    {
                        "cell_line": r["cell_id"],
                        "perturbation": r["perturbation"],
                        "pert_type": r["pert_type"],
                        "signatures": r["signature_count"]
                    }
                    for r in results[:limit]
                ]
            }
        else:
            return {
                "gene": gene_symbol,
                "found": False,
                "message": f"No LINCS expression data found for {gene_symbol}"
            }

    except Exception as e:
        return {
            "gene": gene_symbol,
            "found": False,
            "error": str(e)
        }


async def query_drug_perturbation(
    drug_name: str,
    cell_line_filter: str = None,
    limit: int = 20
) -> Dict[str, Any]:
    """Query how a drug affects gene expression."""
    try:
        where_clause = "WHERE si.pert_iname = $1"
        params = [drug_name]

        if cell_line_filter:
            where_clause += " AND si.cell_id LIKE $2"
            params.append(f"%{cell_line_filter}%")

        query = f"""
        SELECT
            si.pert_iname as drug_name,
            si.cell_id,
            si.pert_dose,
            si.pert_time,
            si.pert_time_unit,
            COUNT(DISTINCT si.sig_id) as signature_count
        FROM lincs_sig_info si
        {where_clause}
        GROUP BY si.pert_iname, si.cell_id, si.pert_dose, si.pert_time, si.pert_time_unit
        ORDER BY signature_count DESC
        LIMIT ${len(params) + 1}
        """

        params.append(limit)
        results = await query_postgres(query, params, database="rescue")

        if results:
            return {
                "drug": drug_name,
                "cell_lines_tested": len(set(r["cell_id"] for r in results)),
                "total_signatures": sum(r["signature_count"] for r in results),
                "perturbation_profiles": [
                    {
                        "cell_line": r["cell_id"],
                        "dose": r["pert_dose"],
                        "time": r["pert_time"],
                        "time_unit": r["pert_time_unit"],
                        "signatures": r["signature_count"]
                    }
                    for r in results[:limit]
                ]
            }
        else:
            return {
                "drug": drug_name,
                "found": False,
                "message": f"No LINCS perturbation data found for {drug_name}"
            }

    except Exception as e:
        return {
            "drug": drug_name,
            "found": False,
            "error": str(e)
        }


async def query_cell_line_specific(gene_symbol: str, cell_line: str) -> Dict[str, Any]:
    """Query expression of a gene in specific cell line."""
    try:
        query = """
        SELECT
            gi.pr_gene_symbol,
            si.cell_id,
            si.pert_iname,
            si.pert_type,
            si.pert_dose,
            si.pert_time,
            COUNT(*) as signature_count
        FROM lincs_gene_info gi
        CROSS JOIN lincs_sig_info si
        WHERE gi.pr_gene_symbol = $1
          AND si.cell_id LIKE $2
        GROUP BY gi.pr_gene_symbol, si.cell_id, si.pert_iname, si.pert_type, si.pert_dose, si.pert_time
        ORDER BY signature_count DESC
        LIMIT 10
        """

        results = await query_postgres(query, [gene_symbol, f"%{cell_line}%"], database="rescue")

        if results:
            return {
                "gene": gene_symbol,
                "cell_line": cell_line,
                "signatures_found": len(results),
                "perturbations": [
                    {
                        "perturbation": r["pert_iname"],
                        "type": r["pert_type"],
                        "dose": r["pert_dose"],
                        "time": r["pert_time"],
                        "signatures": r["signature_count"]
                    }
                    for r in results
                ]
            }
        else:
            return {
                "gene": gene_symbol,
                "cell_line": cell_line,
                "found": False,
                "message": f"No data for {gene_symbol} in {cell_line}"
            }

    except Exception as e:
        return {
            "gene": gene_symbol,
            "cell_line": cell_line,
            "found": False,
            "error": str(e)
        }


# Export for tool registration
__all__ = ["TOOL_DEFINITION", "execute"]
