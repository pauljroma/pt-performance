    "modex_ep_unified_16d_v6_0": EmbeddingSpaceConfig(
        name="modex_ep_unified_16d_v6_0",
        type='drug',
        dimensions=16,
        table_name='modex_ep_unified_16d_v6_0',
        entity_column='drug_name',
        embedding_column='embedding',
        description='MODEX EP Unified 16D v6.0 - Drug-gene rescue matching space (PostgreSQL)',
        status='active'
    ),
}


def get_spaces_by_type(space_type: Literal['gene', 'drug']) -> Dict[str, EmbeddingSpaceConfig]:
    """Get all embedding spaces of a specific type."""
    return {
        space_name: config
        for space_name, config in PRODUCTION_EMBEDDINGS.items()
        if config.type == space_type
    }


def get_available_spaces() -> Dict[str, EmbeddingSpaceConfig]:
    """Get all embedding spaces that are available (active status)."""
    return {
        space_name: config
        for space_name, config in PRODUCTION_EMBEDDINGS.items()
        if config.status == 'active'
    }


def get_connection_config(space_name: str) -> Dict[str, any]:
    """
    Get PostgreSQL connection configuration for a specific embedding space.

    Args:
        space_name: Name of the embedding space

    Returns:
        Dictionary with connection parameters (host, port, database, table_name)
    """
    if space_name not in PRODUCTION_EMBEDDINGS:
        raise ValueError(f"Unknown embedding space: {space_name}")

    config = PRODUCTION_EMBEDDINGS[space_name]

    return {
        'host': config.host,
        'port': config.port,
        'database': config.database,
        'table_name': config.table_name,
        'entity_column': config.entity_column,
        'embedding_column': config.embedding_column
    }


def print_config_summary():
    """Print configuration summary for verification."""
    print("=" * 80)
    print("EMBEDDING CONFIGURATION SUMMARY - PGVECTOR v6.0")
    print("=" * 80)
    print(f"\nTotal Spaces: {len(PRODUCTION_EMBEDDINGS)}")

    gene_spaces = get_spaces_by_type('gene')
    drug_spaces = get_spaces_by_type('drug')
    available_spaces = get_available_spaces()

    print(f"Gene Spaces: {len(gene_spaces)}")
    print(f"Drug Spaces: {len(drug_spaces)}")
    print(f"Available (active): {len(available_spaces)}")
    print(f"Storage Backend: PostgreSQL with pgvector extension")
    print(f"File-based embeddings: 0 (ALL REMOVED)")

    print("\n" + "=" * 80)
    print("AVAILABLE EMBEDDING SPACES (Active/PostgreSQL)")
    print("=" * 80)
    for space_name in sorted(available_spaces.keys()):
        config = available_spaces[space_name]
        print(f"  {config.name:35s} ({config.dimensions:3d}D, {config.type:4s}, table={config.table_name})")

    print("\n" + "=" * 80)
    print("LEGACY FILE-BASED EMBEDDINGS REMOVED (11 total):")
    print("=" * 80)
    legacy_spaces = [
        "ENS_v3_1", "MODEX_Gene_v1_0", "MODEX_Gene_16D_v2_0", "Transcript_v1_Gene",
        "PCA_v4_7", "PLATINUM_QNVS_v2_0", "DFP_PhaseII_v1_0", "DFP_PhaseII_16D_v1_0",
        "Transcript_v1_Drug", "ENS_v3_1_Drug", "PLATINUM_Similarity_v1_0"
    ]
    for i, legacy_name in enumerate(legacy_spaces, 1):
        print(f"  {i:2d}. {legacy_name}")

    print("=" * 80)


if __name__ == "__main__":
    print_config_summary()
