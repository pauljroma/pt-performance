name: Test Edge Functions

on:
  push:
    branches: [main, develop]
    paths:
      - 'supabase/functions/**'
      - 'scripts/tests/**'
      - '.github/workflows/test-edge-functions.yml'
  pull_request:
    branches: [main, develop]
    paths:
      - 'supabase/functions/**'
      - 'scripts/tests/**'
  workflow_dispatch: # Manual trigger

jobs:
  test-edge-functions:
    runs-on: ubuntu-latest
    timeout-minutes: 10

    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Run integration tests
        id: tests
        run: |
          cd scripts/tests
          chmod +x ci_test_edge_functions.sh
          ./ci_test_edge_functions.sh --output test-results.json
        env:
          SUPABASE_URL: ${{ secrets.SUPABASE_URL }}
          SUPABASE_ANON_KEY: ${{ secrets.SUPABASE_ANON_KEY }}
        continue-on-error: true

      - name: Upload test results
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: test-results
          path: scripts/tests/test-results.json
          retention-days: 30

      - name: Parse test results
        if: always()
        run: |
          cd scripts/tests
          if [ -f test-results.json ]; then
            echo "## Test Results" >> $GITHUB_STEP_SUMMARY
            echo "" >> $GITHUB_STEP_SUMMARY

            TOTAL=$(jq -r '.summary.total' test-results.json)
            PASSED=$(jq -r '.summary.passed' test-results.json)
            FAILED=$(jq -r '.summary.failed' test-results.json)
            SKIPPED=$(jq -r '.summary.skipped' test-results.json)
            PASS_RATE=$(jq -r '.summary.pass_rate' test-results.json)
            DURATION=$(jq -r '.test_duration_seconds' test-results.json)

            echo "- **Total Tests:** $TOTAL" >> $GITHUB_STEP_SUMMARY
            echo "- **Passed:** ✅ $PASSED" >> $GITHUB_STEP_SUMMARY
            echo "- **Failed:** ❌ $FAILED" >> $GITHUB_STEP_SUMMARY
            echo "- **Skipped:** ⊘ $SKIPPED" >> $GITHUB_STEP_SUMMARY
            echo "- **Pass Rate:** ${PASS_RATE}%" >> $GITHUB_STEP_SUMMARY
            echo "- **Duration:** ${DURATION}s" >> $GITHUB_STEP_SUMMARY
            echo "" >> $GITHUB_STEP_SUMMARY

            echo "### By Function" >> $GITHUB_STEP_SUMMARY
            echo "" >> $GITHUB_STEP_SUMMARY
            echo "| Function | Passed |" >> $GITHUB_STEP_SUMMARY
            echo "|----------|--------|" >> $GITHUB_STEP_SUMMARY
            echo "| Revenue Analytics | $(jq -r '.by_function.revenue_analytics.actual // 0' test-results.json) |" >> $GITHUB_STEP_SUMMARY
            echo "| Retention Analytics | $(jq -r '.by_function.retention_analytics.actual // 0' test-results.json) |" >> $GITHUB_STEP_SUMMARY
            echo "| Engagement Scoring | $(jq -r '.by_function.engagement_scoring.actual // 0' test-results.json) |" >> $GITHUB_STEP_SUMMARY
            echo "| Training Outcomes | $(jq -r '.by_function.training_outcomes.actual // 0' test-results.json) |" >> $GITHUB_STEP_SUMMARY
            echo "| Executive Dashboard | $(jq -r '.by_function.executive_dashboard.actual // 0' test-results.json) |" >> $GITHUB_STEP_SUMMARY
            echo "| Product Health | $(jq -r '.by_function.product_health.actual // 0' test-results.json) |" >> $GITHUB_STEP_SUMMARY
            echo "| Analytics Pipeline | $(jq -r '.by_function.analytics_pipeline.actual // 0' test-results.json) |" >> $GITHUB_STEP_SUMMARY

            # Fail workflow if tests failed
            if [ "$FAILED" != "0" ]; then
              echo "::error ::$FAILED test(s) failed"
              exit 1
            fi
          else
            echo "::error ::Test results file not found"
            exit 1
          fi

  # Optional: Notify on failure
  notify-failure:
    runs-on: ubuntu-latest
    needs: test-edge-functions
    if: failure()
    steps:
      - name: Notify failure
        run: |
          echo "Edge Function tests failed!"
          echo "Check the test results artifact for details."
