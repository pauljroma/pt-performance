{
  "name": "Weekly Therapist Dashboard Report",
  "description": "Runs every Monday at 8am ET. Generates comprehensive weekly stats, AI summary, and distributes via email, Google Sheets, and Slack.",
  "trigger": {
    "type": "schedule",
    "cron": "0 8 * * 1",
    "timezone": "America/New_York"
  },
  "modules": [
    {
      "id": 1,
      "name": "Schedule Trigger",
      "type": "schedule",
      "description": "Runs every Monday at 8am ET",
      "config": {
        "time": "08:00",
        "day_of_week": "monday",
        "timezone": "America/New_York"
      }
    },
    {
      "id": 2,
      "name": "Query Weekly Stats - Active Patients",
      "type": "http-request",
      "description": "Get count of active patients and new signups",
      "config": {
        "url": "https://rpbxeaxlaoyoqkohytlw.supabase.co/rest/v1/rpc/get_weekly_patient_stats",
        "method": "POST",
        "headers": {
          "Authorization": "Bearer {{env.SUPABASE_SERVICE_KEY}}",
          "Content-Type": "application/json"
        },
        "body": {
          "start_date": "{{formatDate(addDays(now, -7), \"YYYY-MM-DD\")}}",
          "end_date": "{{formatDate(addDays(now, -1), \"YYYY-MM-DD\")}}"
        }
      }
    },
    {
      "id": 3,
      "name": "Query Weekly Stats - Sessions",
      "type": "http-request",
      "description": "Get session completion stats",
      "config": {
        "url": "https://rpbxeaxlaoyoqkohytlw.supabase.co/rest/v1/rpc/get_weekly_session_stats",
        "method": "POST",
        "headers": {
          "Authorization": "Bearer {{env.SUPABASE_SERVICE_KEY}}",
          "Content-Type": "application/json"
        },
        "body": {
          "start_date": "{{formatDate(addDays(now, -7), \"YYYY-MM-DD\")}}",
          "end_date": "{{formatDate(addDays(now, -1), \"YYYY-MM-DD\")}}"
        }
      }
    },
    {
      "id": 4,
      "name": "Query Weekly Stats - Adherence",
      "type": "http-request",
      "description": "Get adherence rates by patient and overall",
      "config": {
        "url": "https://rpbxeaxlaoyoqkohytlw.supabase.co/rest/v1/rpc/get_weekly_adherence_stats",
        "method": "POST",
        "headers": {
          "Authorization": "Bearer {{env.SUPABASE_SERVICE_KEY}}",
          "Content-Type": "application/json"
        },
        "body": {
          "start_date": "{{formatDate(addDays(now, -7), \"YYYY-MM-DD\")}}",
          "end_date": "{{formatDate(addDays(now, -1), \"YYYY-MM-DD\")}}"
        }
      }
    },
    {
      "id": 5,
      "name": "Query Weekly Stats - Readiness",
      "type": "http-request",
      "description": "Get average readiness scores and trends",
      "config": {
        "url": "https://rpbxeaxlaoyoqkohytlw.supabase.co/rest/v1/rpc/get_weekly_readiness_stats",
        "method": "POST",
        "headers": {
          "Authorization": "Bearer {{env.SUPABASE_SERVICE_KEY}}",
          "Content-Type": "application/json"
        },
        "body": {
          "start_date": "{{formatDate(addDays(now, -7), \"YYYY-MM-DD\")}}",
          "end_date": "{{formatDate(addDays(now, -1), \"YYYY-MM-DD\")}}"
        }
      }
    },
    {
      "id": 6,
      "name": "Query Weekly Stats - Pain Flags",
      "type": "http-request",
      "description": "Get pain reports and concerning patterns",
      "config": {
        "url": "https://rpbxeaxlaoyoqkohytlw.supabase.co/rest/v1/rpc/get_weekly_pain_flags",
        "method": "POST",
        "headers": {
          "Authorization": "Bearer {{env.SUPABASE_SERVICE_KEY}}",
          "Content-Type": "application/json"
        },
        "body": {
          "start_date": "{{formatDate(addDays(now, -7), \"YYYY-MM-DD\")}}",
          "end_date": "{{formatDate(addDays(now, -1), \"YYYY-MM-DD\")}}"
        }
      }
    },
    {
      "id": 7,
      "name": "Generate AI Summary",
      "type": "openai-chat",
      "description": "Use OpenAI to generate insights and recommendations",
      "config": {
        "model": "gpt-4-turbo",
        "messages": [
          {
            "role": "system",
            "content": "You are a PT practice analytics assistant. Analyze the weekly stats and provide actionable insights. Be concise but thorough. Highlight wins, concerns, and specific recommendations."
          },
          {
            "role": "user",
            "content": "Generate a weekly summary for the PT practice. Here are the stats from {{formatDate(addDays(now, -7), \"MMM D\")}} to {{formatDate(addDays(now, -1), \"MMM D, YYYY\")}}:\n\n**Patient Stats:**\n- Active Patients: {{2.body.active_patients}}\n- New Signups: {{2.body.new_signups}}\n- Churned: {{2.body.churned_patients}}\n\n**Session Stats:**\n- Total Scheduled: {{3.body.total_scheduled}}\n- Completed: {{3.body.completed}}\n- Skipped: {{3.body.skipped}}\n- Completion Rate: {{3.body.completion_rate}}%\n\n**Adherence:**\n- Overall Adherence: {{4.body.overall_adherence}}%\n- Patients Below 50%: {{4.body.low_adherence_count}}\n- Top Performer: {{4.body.top_performer_name}} ({{4.body.top_performer_rate}}%)\n\n**Readiness:**\n- Average Score: {{5.body.avg_readiness}}\n- Low Readiness Days: {{5.body.low_readiness_count}}\n- Rest Days Triggered: {{5.body.rest_days_triggered}}\n\n**Pain Flags:**\n- Total Reports: {{6.body.total_pain_reports}}\n- High Severity (7+): {{6.body.high_severity_count}}\n- Patients with Recurring Pain: {{6.body.recurring_pain_patients}}\n\nProvide:\n1. Executive Summary (2-3 sentences)\n2. Key Wins (bullet points)\n3. Areas of Concern (bullet points)\n4. Recommended Actions (bullet points)"
          }
        ],
        "temperature": 0.7,
        "max_tokens": 1000
      }
    },
    {
      "id": 8,
      "name": "Append to Google Sheets",
      "type": "google-sheets-add-row",
      "description": "Add weekly stats row to tracking spreadsheet",
      "config": {
        "spreadsheet_id": "{{env.GOOGLE_SHEETS_WEEKLY_REPORT_ID}}",
        "sheet_name": "Weekly Stats",
        "values": [
          "{{formatDate(now, \"YYYY-MM-DD\")}}",
          "{{formatDate(addDays(now, -7), \"YYYY-MM-DD\")}}",
          "{{formatDate(addDays(now, -1), \"YYYY-MM-DD\")}}",
          "{{2.body.active_patients}}",
          "{{2.body.new_signups}}",
          "{{2.body.churned_patients}}",
          "{{3.body.total_scheduled}}",
          "{{3.body.completed}}",
          "{{3.body.skipped}}",
          "{{3.body.completion_rate}}",
          "{{4.body.overall_adherence}}",
          "{{4.body.low_adherence_count}}",
          "{{5.body.avg_readiness}}",
          "{{5.body.low_readiness_count}}",
          "{{5.body.rest_days_triggered}}",
          "{{6.body.total_pain_reports}}",
          "{{6.body.high_severity_count}}",
          "{{6.body.recurring_pain_patients}}"
        ]
      }
    },
    {
      "id": 9,
      "name": "Query Therapist List",
      "type": "http-request",
      "description": "Get all active therapists to send reports",
      "config": {
        "url": "https://rpbxeaxlaoyoqkohytlw.supabase.co/rest/v1/therapists?status=eq.active&select=id,email,full_name",
        "method": "GET",
        "headers": {
          "Authorization": "Bearer {{env.SUPABASE_SERVICE_KEY}}",
          "apikey": "{{env.SUPABASE_SERVICE_KEY}}"
        }
      }
    },
    {
      "id": 10,
      "name": "Iterator - Therapists",
      "type": "iterator",
      "description": "Send report to each therapist",
      "config": {
        "array": "{{9.body}}"
      }
    },
    {
      "id": 11,
      "name": "Send Weekly Report Email",
      "type": "sendgrid-send",
      "description": "Send weekly report email to each therapist",
      "config": {
        "to": "{{10.email}}",
        "from": "reports@ptperformance.app",
        "template_id": "d-weekly-report-template-id",
        "dynamic_template_data": {
          "therapist_name": "{{split(10.full_name, \" \")[0]}}",
          "week_start": "{{formatDate(addDays(now, -7), \"MMMM D\")}}",
          "week_end": "{{formatDate(addDays(now, -1), \"MMMM D, YYYY\")}}",
          "active_patients": "{{2.body.active_patients}}",
          "new_signups": "{{2.body.new_signups}}",
          "churned_patients": "{{2.body.churned_patients}}",
          "sessions_scheduled": "{{3.body.total_scheduled}}",
          "sessions_completed": "{{3.body.completed}}",
          "sessions_skipped": "{{3.body.skipped}}",
          "completion_rate": "{{3.body.completion_rate}}",
          "overall_adherence": "{{4.body.overall_adherence}}",
          "low_adherence_count": "{{4.body.low_adherence_count}}",
          "top_performer_name": "{{4.body.top_performer_name}}",
          "top_performer_rate": "{{4.body.top_performer_rate}}",
          "avg_readiness": "{{5.body.avg_readiness}}",
          "rest_days_triggered": "{{5.body.rest_days_triggered}}",
          "pain_reports": "{{6.body.total_pain_reports}}",
          "high_severity_pain": "{{6.body.high_severity_count}}",
          "ai_summary": "{{7.choices[0].message.content}}",
          "dashboard_url": "https://app.ptperformance.app/dashboard"
        }
      }
    },
    {
      "id": 12,
      "name": "Aggregator",
      "type": "aggregator",
      "description": "Collect results from email sends",
      "config": {
        "group_by": null,
        "aggregate": {
          "emails_sent": "count"
        }
      }
    },
    {
      "id": 13,
      "name": "Post to Slack #pt-metrics",
      "type": "slack-post",
      "description": "Post weekly summary to Slack metrics channel",
      "config": {
        "webhook_url": "{{env.SLACK_METRICS_WEBHOOK_URL}}",
        "blocks": [
          {
            "type": "header",
            "text": {
              "type": "plain_text",
              "text": "Weekly PT Performance Report"
            }
          },
          {
            "type": "context",
            "elements": [
              {
                "type": "mrkdwn",
                "text": "{{formatDate(addDays(now, -7), \"MMM D\")}} - {{formatDate(addDays(now, -1), \"MMM D, YYYY\")}}"
              }
            ]
          },
          {
            "type": "divider"
          },
          {
            "type": "section",
            "fields": [
              {
                "type": "mrkdwn",
                "text": "*Active Patients*\n{{2.body.active_patients}}"
              },
              {
                "type": "mrkdwn",
                "text": "*New Signups*\n{{2.body.new_signups}}"
              },
              {
                "type": "mrkdwn",
                "text": "*Session Completion*\n{{3.body.completion_rate}}%"
              },
              {
                "type": "mrkdwn",
                "text": "*Overall Adherence*\n{{4.body.overall_adherence}}%"
              },
              {
                "type": "mrkdwn",
                "text": "*Avg Readiness*\n{{5.body.avg_readiness}}/100"
              },
              {
                "type": "mrkdwn",
                "text": "*Pain Flags*\n{{6.body.high_severity_count}} high severity"
              }
            ]
          },
          {
            "type": "divider"
          },
          {
            "type": "section",
            "text": {
              "type": "mrkdwn",
              "text": "*AI Insights*\n{{7.choices[0].message.content}}"
            }
          },
          {
            "type": "divider"
          },
          {
            "type": "section",
            "text": {
              "type": "mrkdwn",
              "text": ":email: Reports sent to {{12.emails_sent}} therapists"
            }
          },
          {
            "type": "actions",
            "elements": [
              {
                "type": "button",
                "text": {
                  "type": "plain_text",
                  "text": "View Full Dashboard"
                },
                "url": "https://app.ptperformance.app/dashboard"
              },
              {
                "type": "button",
                "text": {
                  "type": "plain_text",
                  "text": "View Google Sheet"
                },
                "url": "https://docs.google.com/spreadsheets/d/{{env.GOOGLE_SHEETS_WEEKLY_REPORT_ID}}"
              }
            ]
          }
        ]
      }
    },
    {
      "id": 14,
      "name": "Log Report Generation",
      "type": "http-request",
      "description": "Record report generation in audit logs",
      "config": {
        "url": "https://rpbxeaxlaoyoqkohytlw.supabase.co/rest/v1/audit_logs",
        "method": "POST",
        "headers": {
          "Authorization": "Bearer {{env.SUPABASE_SERVICE_KEY}}",
          "apikey": "{{env.SUPABASE_SERVICE_KEY}}",
          "Content-Type": "application/json",
          "Prefer": "return=minimal"
        },
        "body": {
          "action": "weekly_report_generated",
          "entity_type": "system",
          "entity_id": null,
          "metadata": {
            "week_start": "{{formatDate(addDays(now, -7), \"YYYY-MM-DD\")}}",
            "week_end": "{{formatDate(addDays(now, -1), \"YYYY-MM-DD\")}}",
            "emails_sent": "{{12.emails_sent}}",
            "stats_summary": {
              "active_patients": "{{2.body.active_patients}}",
              "completion_rate": "{{3.body.completion_rate}}",
              "adherence_rate": "{{4.body.overall_adherence}}",
              "avg_readiness": "{{5.body.avg_readiness}}",
              "pain_flags": "{{6.body.total_pain_reports}}"
            }
          }
        }
      }
    }
  ],
  "error_handler": {
    "type": "slack-post",
    "config": {
      "webhook_url": "{{env.SLACK_ALERT_WEBHOOK}}",
      "text": ":warning: Weekly dashboard report failed: {{error.message}}"
    }
  },
  "schedule": {
    "type": "weekly",
    "day": "monday",
    "time": "08:00",
    "timezone": "America/New_York"
  },
  "estimated_operations": 20,
  "estimated_cost_per_run": 0.15
}
