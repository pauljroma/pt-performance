name: Build iOS App

on:
  push:
    branches: [ main, develop ]
  workflow_dispatch:

jobs:
  build:
    runs-on: macos-14

    steps:
    - uses: actions/checkout@v4

    - name: Select Xcode
      run: sudo xcode-select -s /Applications/Xcode_15.2.app

    - name: Show Build Info
      run: |
        xcodebuild -version
        swift --version

    - name: Build for Simulator (Test Compilation)
      run: |
        cd ios-app/PTPerformance
        xcodebuild build \
          -project PTPerformance.xcodeproj \
          -scheme PTPerformance \
          -sdk iphonesimulator \
          -configuration Debug

    - name: Build for Device (Release)
      if: github.ref == 'refs/heads/main'
      run: |
        cd ios-app/PTPerformance
        xcodebuild build \
          -project PTPerformance.xcodeproj \
          -scheme PTPerformance \
          -sdk iphoneos \
          -configuration Release \
          CODE_SIGN_IDENTITY="" \
          CODE_SIGNING_REQUIRED=NO \
          CODE_SIGNING_ALLOWED=NO

    - name: Package IPA
      if: github.ref == 'refs/heads/main'
      run: |
        cd ios-app/PTPerformance
        mkdir -p Payload
        cp -r build/Release-iphoneos/PTPerformance.app Payload/
        zip -r PTPerformance.ipa Payload
        rm -rf Payload

    - name: Upload IPA Artifact
      if: github.ref == 'refs/heads/main'
      uses: actions/upload-artifact@v4
      with:
        name: PTPerformance-IPA
        path: ios-app/PTPerformance/PTPerformance.ipa
        retention-days: 30

    - name: Build Summary
      if: success()
      run: |
        echo "✅ Build successful!"
        echo ""
        echo "📱 To install on iPad:"
        echo "1. Download IPA from Actions → Artifacts"
        echo "2. Upload to https://diawi.com"
        echo "3. Open install link on iPad"
